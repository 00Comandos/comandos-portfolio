---
import { Image, getImage } from "astro:assets";
import type { ContentImage } from "~/data/case-studies/types";

type Props = {
  image: ContentImage;
  rounded?: boolean;
  priority?: boolean;
  /** object-fit. Defaults to "cover". Use "contain" for charts/logos. */
  fit?: "cover" | "contain";
};
const { image, rounded = false, priority = false, fit = "cover" } = Astro.props;
const radius = rounded ? "rounded-xl" : "";
const objectClass = fit === "contain" ? "object-contain" : "object-cover";

let mobileSrc: string | undefined;
if (image.kind === "image" && image.mobileImage) {
  const m = await getImage({
    src: image.mobileImage,
    format: "webp",
    widths: [480, 768],
  });
  mobileSrc = m.srcSet.attribute || m.src;
}
---

{
  image.kind === "placeholder" ? (
    <figure class="w-full">
      <div
        class={`placeholder-frame w-full ${radius}`}
        style={`aspect-ratio: ${image.aspect ?? "16 / 9"};`}
        role="img"
        aria-label={image.label}
      >
        <span>{image.label}</span>
      </div>
      {image.caption && (
        <figcaption class="mt-2 text-xs text-[color:var(--color-muted)]">
          {image.caption}
        </figcaption>
      )}
    </figure>
  ) : (
    <figure class="w-full">
      <div class={`overflow-hidden ${radius}`}>
        {mobileSrc ? (
          <picture>
            <source media="(max-width: 767px)" srcset={mobileSrc} />
            <Image
              src={image.image}
              alt={image.alt}
              widths={[640, 960, 1280, 1536]}
              sizes="(min-width: 768px) 720px, 100vw"
              loading={priority ? "eager" : "lazy"}
              decoding="async"
              class:list={["w-full h-auto", objectClass]}
              style={image.aspect ? `aspect-ratio: ${image.aspect};` : undefined}
            />
          </picture>
        ) : (
          <Image
            src={image.image}
            alt={image.alt}
            widths={[480, 768, 1024, 1280]}
            sizes="(min-width: 768px) 720px, 100vw"
            loading={priority ? "eager" : "lazy"}
            decoding="async"
            class:list={["w-full h-auto", objectClass]}
            style={image.aspect ? `aspect-ratio: ${image.aspect};` : undefined}
          />
        )}
      </div>
      {image.caption && (
        <figcaption class="mt-2 text-xs text-[color:var(--color-muted)]">
          {image.caption}
        </figcaption>
      )}
    </figure>
  )
}
