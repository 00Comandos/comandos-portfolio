---
import { Image } from "astro:assets";
import type { Project } from "~/data/projects";

type Props = { cases: readonly Project[] };
const { cases } = Astro.props;
---

<section
  aria-labelledby="related-heading"
  class="pt-16 md:pt-20 pb-24 border-t border-[color:var(--color-border)]"
>
  <div class="container-page">
    <p class="text-xs font-semibold tracking-[0.14em] uppercase text-[color:var(--color-muted)]">
      Keep exploring
    </p>
    <h2
      id="related-heading"
      class="mt-2 text-[1.5rem] md:text-[1.875rem] font-extrabold leading-tight tracking-tight"
    >
      Cases that might interest you
    </h2>

    <ul class="mt-10 grid gap-8 md:grid-cols-3">
      {
        cases.map((c) => (
          <li>
            <a href={`/projects/${c.slug}`} class="related-card group block">
              <div class="aspect-[4/3] overflow-hidden rounded-lg bg-[color:var(--color-paper-soft)] relative">
                <Image
                  src={c.image}
                  alt={`${c.brand} — ${c.title}`}
                  widths={[320, 480, 640, 800]}
                  sizes="(min-width: 768px) 360px, 100vw"
                  loading="lazy"
                  decoding="async"
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
                />
                <span class="absolute top-4 left-4 bg-[color:var(--color-paper)] text-[0.9375rem] font-semibold px-4 py-1.5 rounded-full shadow-[0_1px_3px_rgba(0,0,0,0.14)]">
                  {c.brand}
                </span>
              </div>
              <h3 class="mt-5 text-[1.25rem] md:text-[1.375rem] font-bold leading-[1.25] tracking-tight group-hover:opacity-70 transition-opacity">
                {c.title}
              </h3>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
