---
import { Image } from "astro:assets";
import type { Project } from "~/data/projects";

type Props = { cases: readonly Project[] };
const { cases } = Astro.props;
---

<section
  aria-labelledby="related-heading"
  class="pt-14 md:pt-16 pb-10 md:pb-12 border-t border-[color:var(--color-border)]"
>
  <div class="container-page">
    <p class="text-xs font-semibold tracking-[0.14em] uppercase text-[color:var(--color-muted)]">
      Keep exploring
    </p>
    <h2
      id="related-heading"
      class="mt-2 text-[1.5rem] md:text-[1.875rem] font-extrabold leading-tight tracking-tight"
    >
      Cases that might interest you
    </h2>

    <ul class="mt-10 grid gap-6 md:gap-8 md:grid-cols-3">
      {
        cases.map((c) => (
          <li>
            <a href={`/projects/${c.slug}`} class="related-card group block">
              <div class="flex items-start gap-4 md:block md:gap-0">
                <div class="w-[42%] shrink-0 aspect-[4/3] overflow-hidden bg-[color:var(--color-paper-soft)] md:w-auto md:aspect-[4/3]">
                  <Image
                    src={c.image}
                    alt={`${c.brand} — ${c.title}`}
                    widths={[240, 360, 480, 640, 800]}
                    sizes="(min-width: 768px) 360px, 42vw"
                    loading="lazy"
                    decoding="async"
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
                  />
                </div>
                <div class="flex-1 md:mt-4">
                  <p class="text-[0.72rem] md:text-xs font-semibold tracking-[0.14em] uppercase text-[color:var(--color-muted)]">
                    {c.brand}
                  </p>
                  <h3 class="mt-1.5 md:mt-2 text-[1.0625rem] md:text-[1.25rem] font-bold leading-[1.3] tracking-tight group-hover:opacity-70 transition-opacity">
                    {c.title}
                  </h3>
                </div>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
