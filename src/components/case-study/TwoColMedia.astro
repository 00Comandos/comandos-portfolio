---
import ContentImage from "~/components/case-study/ContentImage.astro";
import type { TwoColMediaItem } from "~/data/case-studies/types";

type Props = { items: readonly TwoColMediaItem[] };
const { items } = Astro.props;
---

<div class="grid gap-10 md:grid-cols-2 md:gap-6">
  {
    items.map((it) => (
      <div>
        {it.kicker && (
          <p class="text-[0.875rem] font-bold uppercase tracking-[0.04em] text-[color:var(--color-ink)]">
            {it.kicker}
          </p>
        )}
        <p class:list={[
          it.kicker ? "mt-1" : "",
          "text-[1.0625rem] leading-[1.4] text-[color:var(--color-ink)]",
        ]}>
          {it.title}
        </p>
        <div class="mt-4">
          <ContentImage image={it.image} />
        </div>
        {it.detail && (
          <p class="mt-4 text-[0.95rem] leading-[1.6] text-[color:var(--color-ink-soft)]">
            {!it.kicker && <span aria-hidden="true" class="mr-1.5">✓</span>}
            {it.detail}
          </p>
        )}
      </div>
    ))
  }
</div>
