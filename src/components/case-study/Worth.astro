---
import ContentImage from "~/components/case-study/ContentImage.astro";
import SectionChip from "~/components/case-study/SectionChip.astro";
import Divider from "~/components/case-study/Divider.astro";
import Checklist from "~/components/case-study/Checklist.astro";
import ImageGrid from "~/components/case-study/ImageGrid.astro";
import ResponsiveMedia from "~/components/case-study/ResponsiveMedia.astro";
import type { CaseStudyContent } from "~/data/case-studies/types";

type Props = { content: CaseStudyContent["worth"] };
const { content } = Astro.props;
---

<section id="worth" class="pb-10 md:pb-12">
  <div class="cs-body">
    <div class="worth-blocks space-y-14 md:space-y-16">
      {
        content.blocks.map((block) => {
          if (block.kind === "divider") return <Divider variant={block.variant ?? "hatched"} />;
          if (block.kind === "chip") {
            return (
              <div data-chip="true">
                <SectionChip variant={block.icon} label={block.label} />
              </div>
            );
          }
          if (block.kind === "intro") {
            return (
              <div>
                {block.label && (
                  <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[color:var(--color-muted)]">
                    {block.label}
                  </p>
                )}
                <h3 class="display-serif mt-2 text-[2rem] md:text-[2.375rem]">
                  {block.heading}
                </h3>
                {block.body && (
                  <p class="mt-3 text-[1rem] leading-[1.7] text-[color:var(--color-ink-soft)]">
                    {block.body}
                  </p>
                )}
              </div>
            );
          }
          if (block.kind === "text") {
            return (
              <p class="text-[1rem] leading-[1.7] text-[color:var(--color-ink-soft)]">
                {block.text}
              </p>
            );
          }
          if (block.kind === "image") {
            return <ContentImage image={block.image} rounded={block.rounded === true} />;
          }
          if (block.kind === "checklist") {
            return (
              <div>
                {block.heading && (
                  <p class="mb-3 text-[0.95rem] font-bold">{block.heading}</p>
                )}
                <Checklist items={block.items} />
              </div>
            );
          }
          if (block.kind === "big-heading") {
            return (
              <h3 class="display-serif text-center text-[2.25rem] md:text-[3rem]">
                {block.heading}
              </h3>
            );
          }
          if (block.kind === "image-grid") {
            return <ImageGrid columns={block.columns} images={block.images} />;
          }
          if (block.kind === "responsive-media") {
            return <ResponsiveMedia desktop={block.desktop} mobile={block.mobile} />;
          }
          if (block.kind === "before-after") {
            return (
              <div>
                <div class="flex items-center justify-between mb-3 text-sm">
                  <span class="inline-flex items-center bg-[color:var(--color-paper-soft)] border border-[color:var(--color-border)] rounded-full px-4 py-1.5 font-semibold">
                    Before
                  </span>
                  <span class="inline-flex items-center gap-2 bg-[color:var(--color-paper-soft)] border border-[color:var(--color-border)] rounded-full px-4 py-1.5 font-semibold">
                    New
                    <span class="text-[color:var(--color-accent-mint)]">{block.impact}</span>
                  </span>
                </div>
                <div class="grid md:grid-cols-2 gap-4 md:gap-6">
                  <ContentImage image={block.before} />
                  <ContentImage image={block.after} />
                </div>
              </div>
            );
          }
          return null;
        })
      }
    </div>
  </div>
</section>

<style>
  .worth-blocks > [data-chip] {
    margin-block-end: 0.75rem !important;
  }
</style>
