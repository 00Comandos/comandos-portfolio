---
type Props = { variant?: "dark" | "light" };
const { variant = "light" } = Astro.props;
const color = variant === "dark" ? "rgba(255,255,255,0.35)" : "rgba(11,11,11,0.35)";
---

<div
  class="my-10 md:my-14 h-[10px] w-full"
  aria-hidden="true"
  style={`background-image: repeating-linear-gradient(-45deg, ${color} 0 1px, transparent 1px 8px);`}
>
</div>
