---
type Scene =
  | "launch"
  | "rise"
  | "retention"
  | "multiply"
  | "audience"
  | "ink"
  | "biometric"
  | "certified"
  | "progress"
  | "documents"
  | "signed-growth"
  | "love"
  | "reactivate"
  | "sprint"
  | "unify"
  | "flow"
  | "streak"
  | "orbit"
  | "sync"
  | "whisper"
  | "lap"
  | "magnet"
  | "summit"
  | "anydevice"
  | "renew"
  | "simmer"
  | "tap-pay"
  | "refer"
  | "parking"
  | "activate"
  | "wayfind";

type Props = { scene: Scene; class?: string };
const { scene, class: className = "" } = Astro.props;
---

<div class:list={["stat-art", `stat-art--${scene}`, className]}>
  <svg
    viewBox="0 0 120 80"
    width="120"
    height="80"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    {
      scene === "launch" && (
        <>
          <g class="art-rocket">
            <path
              d="M60 18 C66 18 70 24 70 32 L70 46 L50 46 L50 32 C50 24 54 18 60 18 Z"
              class="stroke"
              stroke-width="1.5"
              stroke-linejoin="round"
            />
            <circle cx="60" cy="32" r="3.2" class="stroke" stroke-width="1.5" />
            <path
              d="M50 42 L44 54 L50 50"
              class="stroke"
              stroke-width="1.5"
              stroke-linejoin="round"
            />
            <path
              d="M70 42 L76 54 L70 50"
              class="stroke"
              stroke-width="1.5"
              stroke-linejoin="round"
            />
            <path
              d="M55 46 L58 58 L60 52 L62 58 L65 46"
              class="flame stroke-accent"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </g>
          <circle cx="38" cy="66" r="1.4" class="spark spark-1" />
          <circle cx="82" cy="68" r="1.1" class="spark spark-2" />
          <circle cx="30" cy="58" r="0.9" class="spark spark-3" />
          <circle cx="90" cy="58" r="1.2" class="spark spark-4" />
        </>
      )
    }

    {
      scene === "rise" && (
        <>
          <line
            x1="28"
            y1="62"
            x2="92"
            y2="62"
            class="stroke axis"
            stroke-width="1"
            stroke-linecap="round"
          />
          <rect x="38" y="46" width="10" height="16" class="bar bar-1" rx="1" />
          <rect x="55" y="36" width="10" height="26" class="bar bar-2" rx="1" />
          <rect x="72" y="26" width="10" height="36" class="bar bar-3" rx="1" />
          <polyline
            points="30,52 45,44 62,34 80,22"
            class="stroke-accent trend"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
          <circle cx="80" cy="22" r="2.5" class="trend-dot" />
        </>
      )
    }

    {
      scene === "retention" && (
        <>
          <path
            d="M60 16 L80 24 L80 42 C80 54 72 62 60 66 C48 62 40 54 40 42 L40 24 Z"
            class="stroke shield"
            stroke-width="1.5"
            stroke-linejoin="round"
          />
          <path
            d="M51 40 L57 46 L69 32"
            class="stroke-accent check"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </>
      )
    }

    {
      scene === "multiply" && (
        <>
          <rect
            class="mul-card mul-card-1"
            x="22"
            y="36"
            width="46"
            height="28"
            rx="3"
          />
          <rect
            class="mul-card mul-card-2"
            x="37"
            y="28"
            width="46"
            height="28"
            rx="3"
          />
          <rect
            class="mul-card mul-card-3 mul-card-accent"
            x="52"
            y="20"
            width="46"
            height="28"
            rx="3"
          />
          <rect
            class="mul-chip"
            x="58"
            y="26"
            width="7"
            height="5"
            rx="1"
          />
        </>
      )
    }

    {
      scene === "ink" && (
        <>
          <line
            x1="20"
            y1="58"
            x2="100"
            y2="58"
            class="ink-baseline"
            stroke-dasharray="2 4"
            stroke-width="1"
          />
          <path
            d="M24 56 Q32 38 42 48 T62 42 Q70 28 80 40 Q88 52 96 46"
            class="ink-line"
            fill="none"
            stroke-width="2.2"
            stroke-linecap="round"
          />
          <circle cx="96" cy="46" r="2.8" class="ink-tip" />
        </>
      )
    }

    {
      scene === "documents" && (
        <g class="docs">
          <path
            d="M32 20 L50 20 L54 24 L54 60 L32 60 Z"
            class="doc doc-1"
            fill="none"
            stroke-width="1.5"
            stroke-linejoin="round"
          />
          <path
            d="M46 26 L64 26 L68 30 L68 66 L46 66 Z"
            class="doc doc-2"
            fill="none"
            stroke-width="1.5"
            stroke-linejoin="round"
          />
          <g class="doc doc-3">
            <path
              d="M60 32 L78 32 L82 36 L82 72 L60 72 Z"
              class="doc-paper"
              fill="none"
              stroke-width="1.8"
              stroke-linejoin="round"
            />
            <path
              d="M78 32 L78 36 L82 36"
              class="doc-fold"
              fill="none"
              stroke-width="1.6"
              stroke-linejoin="round"
            />
            <path
              d="M64 62 Q70 55 74 60 T80 58"
              class="doc-sig"
              fill="none"
              stroke-width="1.6"
              stroke-linecap="round"
            />
          </g>
        </g>
      )
    }

    {
      scene === "progress" && (
        <g class="prog">
          <circle cx="60" cy="40" r="22" class="prog-bg" stroke-width="3" />
          <circle
            cx="60"
            cy="40"
            r="22"
            class="prog-fill"
            stroke-width="3"
            transform="rotate(-90 60 40)"
          />
          <path
            d="M52 40 L58 46 L68 32"
            class="prog-check"
            stroke-width="2.2"
          />
        </g>
      )
    }

    {
      scene === "biometric" && (
        <g class="bio">
          <ellipse cx="60" cy="40" rx="18" ry="22" class="bio-face" />
          <circle cx="52" cy="32" r="1.4" class="bio-dot bio-d-1" />
          <circle cx="60" cy="30" r="1.4" class="bio-dot bio-d-2" />
          <circle cx="68" cy="32" r="1.4" class="bio-dot bio-d-3" />
          <circle cx="50" cy="42" r="1.4" class="bio-dot bio-d-4" />
          <circle cx="70" cy="42" r="1.4" class="bio-dot bio-d-5" />
          <circle cx="56" cy="52" r="1.4" class="bio-dot bio-d-6" />
          <circle cx="64" cy="52" r="1.4" class="bio-dot bio-d-7" />
          <line x1="40" y1="40" x2="80" y2="40" class="bio-scan" />
        </g>
      )
    }

    {
      scene === "certified" && (
        <g class="cert">
          <path
            d="M48 46 L48 70 L54 62 L60 68 L66 62 L72 70 L72 46"
            class="cert-ribbon"
          />
          <circle cx="60" cy="34" r="16" class="cert-medal" />
          <circle cx="60" cy="34" r="11" class="cert-inner" />
          <path d="M54 34 L58 38 L66 28" class="cert-check" />
        </g>
      )
    }

    {
      scene === "signed-growth" && (
        <g class="sg">
          <path
            d="M36 18 L70 18 L78 26 L78 66 L36 66 Z"
            class="sg-doc"
            fill="none"
            stroke-width="1.5"
            stroke-linejoin="round"
          />
          <path
            d="M70 18 L70 26 L78 26"
            class="sg-fold"
            fill="none"
            stroke-width="1.5"
            stroke-linejoin="round"
          />
          <line x1="42" y1="32" x2="70" y2="32" class="sg-ruled" stroke-width="1" />
          <line x1="42" y1="38" x2="66" y2="38" class="sg-ruled" stroke-width="1" />
          <line x1="42" y1="44" x2="68" y2="44" class="sg-ruled" stroke-width="1" />
          <path
            d="M42 58 Q48 50 54 56 T66 54 Q72 48 76 54"
            class="sg-sig"
            fill="none"
            stroke-width="2"
            stroke-linecap="round"
          />
          <path
            d="M88 60 L98 48 M92 48 L98 48 L98 54"
            class="sg-arrow"
            fill="none"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </g>
      )
    }

    {
      scene === "sprint" && (
        <g class="sprint">
          <rect x="57" y="14" width="6" height="4" class="sprint-crown" rx="0.8" />
          <line x1="60" y1="10" x2="60" y2="14" class="sprint-stem" stroke-width="1.5" stroke-linecap="round" />
          <circle cx="60" cy="44" r="22" class="sprint-body" fill="none" stroke-width="1.8" />
          <line x1="60" y1="24" x2="60" y2="27" class="sprint-tick" stroke-width="1.5" stroke-linecap="round" />
          <line x1="80" y1="44" x2="77" y2="44" class="sprint-tick" stroke-width="1.5" stroke-linecap="round" />
          <line x1="60" y1="64" x2="60" y2="61" class="sprint-tick" stroke-width="1.5" stroke-linecap="round" />
          <line x1="40" y1="44" x2="43" y2="44" class="sprint-tick" stroke-width="1.5" stroke-linecap="round" />
          <line x1="60" y1="44" x2="60" y2="26" class="sprint-needle" stroke-width="2" stroke-linecap="round" />
          <circle cx="60" cy="44" r="2.5" class="sprint-pivot" />
        </g>
      )
    }

    {
      scene === "unify" && (
        <g class="unify">
          <rect x="30" y="22" width="14" height="14" class="uni-cell uni-c-1" rx="1.8" />
          <rect x="53" y="22" width="14" height="14" class="uni-cell uni-c-2" rx="1.8" />
          <rect x="76" y="22" width="14" height="14" class="uni-cell uni-c-3" rx="1.8" />
          <rect x="30" y="45" width="14" height="14" class="uni-cell uni-c-4" rx="1.8" />
          <rect x="53" y="45" width="14" height="14" class="uni-cell uni-c-5" rx="1.8" />
          <rect x="76" y="45" width="14" height="14" class="uni-cell uni-c-6" rx="1.8" />
          <path
            d="M44 29 L53 29 M67 29 L76 29 M44 52 L53 52 M67 52 L76 52 M37 36 L37 45 M60 36 L60 45 M83 36 L83 45"
            class="uni-link"
            fill="none"
            stroke-width="1.5"
            stroke-linecap="round"
          />
        </g>
      )
    }

    {
      scene === "flow" && (
        <g class="flow">
          <path
            d="M30 46 Q42 46 50 32 Q60 20 70 32 Q78 46 90 46"
            class="flow-long"
            fill="none"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-dasharray="3 3"
          />
          <line x1="30" y1="46" x2="90" y2="46" class="flow-short" stroke-width="2.2" stroke-linecap="round" />
          <circle cx="30" cy="46" r="4.5" class="flow-node flow-n-1" />
          <circle cx="60" cy="26" r="4.5" class="flow-node flow-n-2" />
          <circle cx="90" cy="46" r="4.5" class="flow-node flow-n-3" />
          <path d="M84 60 L90 66 L102 54" class="flow-check" fill="none" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
        </g>
      )
    }

    {
      scene === "reactivate" && (
        <g class="react">
          <path
            d="M34 26 L78 26 Q84 26 84 32 L84 48 Q84 54 78 54 L58 54 L52 62 L52 54 L40 54 Q34 54 34 48 L34 32 Q34 26 34 26 Z"
            class="react-bubble"
            fill="none"
            stroke-width="1.5"
            stroke-linejoin="round"
          />
          <circle cx="50" cy="40" r="1.8" class="react-dot react-d-1" />
          <circle cx="58" cy="40" r="1.8" class="react-dot react-d-2" />
          <circle cx="66" cy="40" r="1.8" class="react-dot react-d-3" />
          <circle cx="80" cy="26" r="3" class="react-pulse" />
          <circle cx="80" cy="26" r="3" class="react-ring" fill="none" stroke-width="1.2" />
        </g>
      )
    }

    {
      scene === "love" && (
        <g class="love">
          <path
            d="M60 58 C52 52 42 46 42 36 C42 30 47 26 52 26 C56 26 58 28 60 31 C62 28 64 26 68 26 C73 26 78 30 78 36 C78 46 68 52 60 58 Z"
            class="love-heart"
          />
          <circle cx="28" cy="28" r="1.8" class="love-spark love-s-1" />
          <circle cx="92" cy="30" r="1.8" class="love-spark love-s-2" />
          <circle cx="32" cy="60" r="1.5" class="love-spark love-s-3" />
          <circle cx="92" cy="60" r="1.5" class="love-spark love-s-4" />
          <circle cx="22" cy="46" r="1" class="love-spark love-s-5" />
          <circle cx="100" cy="46" r="1" class="love-spark love-s-6" />
        </g>
      )
    }

    {
      scene === "streak" && (
        <g class="streak">
          <line
            x1="22"
            y1="62"
            x2="98"
            y2="62"
            class="streak-base"
            stroke-dasharray="2 3"
            stroke-width="1"
            stroke-linecap="round"
          />
          <rect x="24" y="54" width="6" height="8" rx="1" class="streak-bar streak-b-1" />
          <rect x="34" y="50" width="6" height="12" rx="1" class="streak-bar streak-b-2" />
          <rect x="44" y="46" width="6" height="16" rx="1" class="streak-bar streak-b-3" />
          <rect x="54" y="40" width="6" height="22" rx="1" class="streak-bar streak-b-4" />
          <rect x="64" y="34" width="6" height="28" rx="1" class="streak-bar streak-b-5" />
          <rect x="74" y="28" width="6" height="34" rx="1" class="streak-bar streak-b-6" />
          <rect x="84" y="22" width="6" height="40" rx="1" class="streak-bar streak-b-7" />
          <rect x="94" y="16" width="6" height="46" rx="1" class="streak-bar streak-bar-hi streak-b-8" />
          <path
            d="M27 54 L37 50 L47 46 L57 40 L67 34 L77 28 L87 22 L97 16"
            class="streak-trend"
            fill="none"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
          <circle cx="97" cy="16" r="2.6" class="streak-tip" />
        </g>
      )
    }

    {
      scene === "orbit" && (
        <g class="orbit">
          <circle cx="60" cy="40" r="26" class="orbit-ring orbit-ring-outer" fill="none" stroke-dasharray="2 3" stroke-width="1" />
          <circle cx="60" cy="40" r="16" class="orbit-ring orbit-ring-inner" fill="none" stroke-dasharray="2 3" stroke-width="1" />
          <circle cx="60" cy="40" r="5" class="orbit-core" />
          <circle cx="60" cy="40" r="10" class="orbit-pulse" fill="none" stroke-width="1.2" />
          <circle cx="60" cy="14" r="3.2" class="orbit-node orbit-n-1" />
          <circle cx="86" cy="40" r="3.2" class="orbit-node orbit-n-2" />
          <circle cx="48" cy="62" r="3.2" class="orbit-node orbit-n-3" />
          <circle cx="34" cy="40" r="3.2" class="orbit-node orbit-n-4" />
        </g>
      )
    }

    {
      scene === "sync" && (
        <g class="sync">
          <rect x="22" y="26" width="28" height="28" rx="6" class="sync-device sync-watch" fill="none" stroke-width="1.6" />
          <rect x="34" y="21" width="4" height="5" rx="0.8" class="sync-crown" />
          <line x1="36" y1="17" x2="36" y2="21" class="sync-stem" stroke-width="1.4" stroke-linecap="round" />
          <circle cx="36" cy="40" r="4" class="sync-face" fill="none" stroke-width="1.2" />
          <rect x="70" y="22" width="22" height="36" rx="4" class="sync-device sync-phone" fill="none" stroke-width="1.6" />
          <path d="M76 38 L80 42 L88 32" class="sync-check" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M50 40 Q60 22 70 40" class="sync-arc" fill="none" stroke-width="1.4" stroke-linecap="round" stroke-dasharray="2 3" />
          <circle cx="60" cy="28" r="2" class="sync-packet" />
        </g>
      )
    }

    {
      scene === "whisper" && (
        <g class="whisper">
          <path
            d="M28 34 L28 46 L42 46 L58 54 L58 26 L42 34 Z"
            class="wh-horn"
            fill="none"
            stroke-width="1.5"
            stroke-linejoin="round"
          />
          <path d="M66 30 Q72 40 66 50" class="wh-wave wh-w-1" fill="none" stroke-width="1.5" stroke-linecap="round" />
          <path d="M76 24 Q84 40 76 56" class="wh-wave wh-w-2" fill="none" stroke-width="1.5" stroke-linecap="round" />
          <path d="M86 18 Q96 40 86 62" class="wh-wave wh-w-3" fill="none" stroke-width="1.5" stroke-linecap="round" />
          <circle cx="100" cy="22" r="2.2" class="wh-recv wh-r-1" />
          <circle cx="102" cy="40" r="2.2" class="wh-recv wh-r-2" />
          <circle cx="100" cy="58" r="2.2" class="wh-recv wh-r-3" />
        </g>
      )
    }

    {
      scene === "lap" && (
        <g class="lap">
          <ellipse cx="60" cy="40" rx="32" ry="18" class="lap-track lap-track-outer" fill="none" stroke-width="1.4" stroke-dasharray="2 3" />
          <ellipse cx="60" cy="40" rx="20" ry="8" class="lap-track lap-track-inner" fill="none" stroke-width="1" stroke-dasharray="2 3" />
          <path
            d="M60 58 L84 58"
            class="lap-finish"
            stroke-width="1.6"
            stroke-linecap="round"
          />
          <g class="lap-runner">
            <ellipse cx="28" cy="40" rx="4.5" ry="3" class="lap-shoe" />
          </g>
          <path
            d="M52 22 L60 18 L68 22 M60 18 L60 28"
            class="lap-arrow"
            fill="none"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </g>
      )
    }

    {
      scene === "magnet" && (
        <g class="magnet">
          <path
            d="M24 22 L24 42 A14 14 0 0 0 52 42 L52 22 L44 22 L44 42 A6 6 0 0 1 32 42 L32 22 Z"
            class="mag-body"
            fill="none"
            stroke-width="1.6"
            stroke-linejoin="round"
          />
          <rect x="24" y="18" width="8" height="6" class="mag-pole mag-pole-n" rx="1" />
          <rect x="44" y="18" width="8" height="6" class="mag-pole mag-pole-s" rx="1" />
          <path
            d="M60 28 Q74 28 80 40 Q74 52 60 52"
            class="mag-field mag-f-1"
            fill="none"
            stroke-width="1.4"
            stroke-linecap="round"
            stroke-dasharray="3 3"
          />
          <path
            d="M60 22 Q82 22 90 40 Q82 58 60 58"
            class="mag-field mag-f-2"
            fill="none"
            stroke-width="1.4"
            stroke-linecap="round"
            stroke-dasharray="3 3"
          />
          <circle cx="94" cy="24" r="2.4" class="mag-dot mag-d-1" />
          <circle cx="102" cy="40" r="2.4" class="mag-dot mag-d-2" />
          <circle cx="94" cy="56" r="2.4" class="mag-dot mag-d-3" />
        </g>
      )
    }

    {
      scene === "summit" && (
        <g class="summit">
          <path
            d="M18 62 L46 30 L58 44 L72 26 L102 62 Z"
            class="sum-mount"
            fill="none"
            stroke-width="1.6"
            stroke-linejoin="round"
          />
          <path
            d="M66 32 L72 26 L78 32 L75 35 L72 31 L69 35 Z"
            class="sum-snow"
          />
          <path
            d="M26 60 Q36 52 44 44 Q54 36 60 32 Q66 30 72 26"
            class="sum-path"
            fill="none"
            stroke-width="1.4"
            stroke-linecap="round"
            stroke-dasharray="3 3"
          />
          <line x1="72" y1="26" x2="72" y2="12" class="sum-pole" stroke-width="1.5" stroke-linecap="round" />
          <path d="M72 12 L86 16 L72 20 Z" class="sum-flag" />
          <circle cx="60" cy="32" r="2.6" class="sum-climber" />
          <path
            d="M68 22 L71 25 L78 16"
            class="sum-check"
            fill="none"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </g>
      )
    }

    {
      scene === "anydevice" && (
        <g class="anydev">
          <rect
            x="18"
            y="26"
            width="26"
            height="36"
            rx="3"
            class="ad-device ad-d-1"
            fill="none"
            stroke-width="1.4"
          />
          <rect
            x="34"
            y="18"
            width="52"
            height="36"
            rx="4"
            class="ad-device ad-d-main"
            fill="none"
            stroke-width="1.8"
          />
          <circle cx="82" cy="36" r="1.4" class="ad-dot" />
          <rect
            x="78"
            y="28"
            width="22"
            height="34"
            rx="3"
            class="ad-device ad-d-3"
            fill="none"
            stroke-width="1.4"
          />
          <circle cx="96" cy="14" r="6" class="ad-badge" />
          <path
            d="M93 14 L95.5 16.5 L100 11"
            class="ad-check"
            fill="none"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </g>
      )
    }

    {
      scene === "renew" && (
        <g class="renew">
          <path
            d="M40 40 A20 20 0 0 1 80 30"
            class="rnw-arc rnw-a-1"
            fill="none"
            stroke-width="1.6"
            stroke-linecap="round"
          />
          <path
            d="M76 22 L80 30 L72 32"
            class="rnw-head rnw-h-1"
            fill="none"
