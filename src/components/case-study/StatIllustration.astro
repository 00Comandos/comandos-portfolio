<style>
  .stat-art {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 120px;
    height: 80px;
    color: var(--color-ink);
    transition: transform 0.35s ease;
  }
  .stat-art svg {
    overflow: visible;
  }

  .stroke {
    stroke: currentColor;
    fill: none;
  }
  .stroke-accent {
    stroke: var(--color-accent-mint);
    fill: none;
  }

  /* ——— Scroll-in: stroke draw + fade ——— */
  .stroke,
  .stroke-accent {
    stroke-dasharray: 220;
    stroke-dashoffset: 220;
    opacity: 0;
  }
  :global(.stat[data-in-view="true"]) .stroke,
  :global(.stat[data-in-view="true"]) .stroke-accent {
    stroke-dashoffset: 0;
    opacity: 1;
    transition:
      stroke-dashoffset 1.4s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.35s ease-out;
  }
  .spark,
  .trend-dot {
    opacity: 0;
  }
  :global(.stat[data-in-view="true"]) .spark,
  :global(.stat[data-in-view="true"]) .trend-dot {
    opacity: 1;
    transition: opacity 0.5s ease-out 0.9s;
  }

  :global(.stat):hover .stat-art {
    transform: translateY(-2px);
  }

  /* ———— Scene: launch ———— */
  .art-rocket {
    transform-origin: 60px 52px;
    transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }
  :global(.stat):hover .art-rocket {
    transform: translateY(-5px);
  }
  @keyframes flame-flicker {
    0%, 100% { transform: scaleY(1); }
    50% { transform: scaleY(1.25) translateY(1px); }
  }
  .flame {
    transform-origin: 60px 46px;
    animation: flame-flicker 0.45s ease-in-out infinite;
  }
  .spark {
    fill: color-mix(in srgb, var(--color-ink) 55%, transparent);
  }
  @keyframes spark-drift {
    0% { transform: translate(0, 0); opacity: 0.9; }
    100% { transform: translate(-3px, 6px); opacity: 0; }
  }
  .spark-1 { animation: spark-drift 1.6s ease-out infinite; }
  .spark-2 { animation: spark-drift 1.8s ease-out infinite 0.25s; }
  .spark-3 { animation: spark-drift 2.0s ease-out infinite 0.6s; }
  .spark-4 { animation: spark-drift 1.7s ease-out infinite 0.9s; }

  /* ———— Scene: rise ———— */
  .bar {
    fill: color-mix(in srgb, var(--color-ink) 14%, transparent);
    transform-origin: center bottom;
    transform: scaleY(0);
  }
  .trend-dot {
    fill: var(--color-accent-mint);
  }
  :global(.stat[data-in-view="true"]) .bar-1 {
    transform: scaleY(1);
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.1s;
  }
  :global(.stat[data-in-view="true"]) .bar-2 {
    transform: scaleY(1);
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.25s;
  }
  :global(.stat[data-in-view="true"]) .bar-3 {
    transform: scaleY(1);
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.4s;
  }
  :global(.stat[data-in-view="true"]) .trend {
    transition-delay: 0.6s;
  }
  :global(.stat[data-in-view="true"]) .trend-dot {
    transition-delay: 1.2s;
  }
  @keyframes bar-breathe {
    0%, 100% { transform: scaleY(1); }
    50% { transform: scaleY(1.04); }
  }
  :global(.stat):hover .bar-1 {
    animation: bar-breathe 1.1s ease-in-out infinite;
  }
  :global(.stat):hover .bar-2 {
    animation: bar-breathe 1.1s ease-in-out 0.12s infinite;
  }
  :global(.stat):hover .bar-3 {
    animation: bar-breathe 1.1s ease-in-out 0.24s infinite;
  }

  /* ———— Scene: retention ———— */
  .shield {
    transform-origin: 60px 40px;
    transition: transform 0.4s ease;
  }
  @keyframes shield-breathe {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.03); }
  }
  :global(.stat[data-in-view="true"]) .shield {
    animation: shield-breathe 3.2s ease-in-out infinite;
  }
  :global(.stat):hover .shield {
    animation-duration: 1.4s;
  }
  @keyframes check-glow {
    0%, 100% { stroke-width: 2; filter: drop-shadow(0 0 0 transparent); }
    50% { stroke-width: 2.4; filter: drop-shadow(0 0 3px var(--color-accent-mint)); }
  }
  :global(.stat):hover .check {
    animation: check-glow 1.2s ease-in-out;
  }

  /* ———— Scene: multiply (stacked credit cards) ———— */
  .mul-card {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 0.55s ease-out,
      transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .mul-card-accent {
    stroke: var(--color-accent-mint);
  }
  .mul-chip {
    fill: none;
    stroke: var(--color-accent-mint);
    stroke-width: 1;
    opacity: 0;
    transform-origin: 61.5px 28.5px;
    transition:
      opacity 0.35s ease-out,
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  :global(.stat[data-in-view="true"]) .mul-card-1 {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.1s;
  }
  :global(.stat[data-in-view="true"]) .mul-card-2 {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.28s;
  }
  :global(.stat[data-in-view="true"]) .mul-card-3 {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.46s;
  }
  :global(.stat[data-in-view="true"]) .mul-chip {
    opacity: 1;
    transition-delay: 0.7s;
  }
  :global(.stat):hover .mul-card-1 {
    transform: translate(-4px, 2px);
    transition-delay: 0s;
  }
  :global(.stat):hover .mul-card-3 {
    transform: translate(4px, -3px);
    transition-delay: 0s;
  }
  :global(.stat):hover .mul-chip {
    transform: translate(4px, -3px);
    transition-delay: 0s;
  }

  /* ———— Scene: ink (signature draw) ———— */
  .ink-baseline {
    stroke: color-mix(in srgb, currentColor 35%, transparent);
    fill: none;
    opacity: 0;
    transition: opacity 0.4s ease-out 0.15s;
  }
  .ink-line {
    stroke: currentColor;
    stroke-dasharray: 180;
    stroke-dashoffset: 180;
    opacity: 0;
    transition:
      stroke-dashoffset 1.3s cubic-bezier(0.22, 1, 0.36, 1) 0.3s,
      opacity 0.35s ease-out 0.3s;
  }
  .ink-tip {
    fill: var(--color-accent-mint);
    opacity: 0;
    transform-origin: 96px 46px;
    transition: opacity 0.3s ease-out 1.5s;
  }
  :global(.stat[data-in-view="true"]) .ink-baseline {
    opacity: 1;
  }
  :global(.stat[data-in-view="true"]) .ink-line {
    stroke-dashoffset: 0;
    opacity: 1;
  }
  :global(.stat[data-in-view="true"]) .ink-tip {
    opacity: 1;
    animation: ink-pulse 1.4s ease-in-out infinite 1.6s;
  }
  @keyframes ink-pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.25); }
  }
  :global(.stat):hover .ink-line {
    animation: ink-redraw 1.2s ease-out;
  }
  @keyframes ink-redraw {
    from { stroke-dashoffset: 180; }
    to { stroke-dashoffset: 0; }
  }

  /* ———— Scene: documents (3 stacked docs + signature) ———— */
  .doc {
    opacity: 0;
    transform: translateY(10px);
    transform-origin: center;
    transition:
      opacity 0.45s ease-out,
      transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .doc-1,
  .doc-2 {
    stroke: currentColor;
  }
  .doc-3 .doc-paper,
  .doc-3 .doc-fold {
    stroke: var(--color-accent-mint);
    fill: none;
  }
  .doc-sig {
    stroke: var(--color-accent-mint);
    stroke-dasharray: 32;
    stroke-dashoffset: 32;
    opacity: 0;
    transition:
      stroke-dashoffset 0.6s cubic-bezier(0.22, 1, 0.36, 1) 0.9s,
      opacity 0.3s ease-out 0.9s;
  }
  :global(.stat[data-in-view="true"]) .doc-1 {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.1s;
  }
  :global(.stat[data-in-view="true"]) .doc-2 {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.3s;
  }
  :global(.stat[data-in-view="true"]) .doc-3 {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.55s;
  }
  :global(.stat[data-in-view="true"]) .doc-sig {
    stroke-dashoffset: 0;
    opacity: 1;
  }

  /* ———— Scene: progress (circular completion ring) ———— */
  .prog-bg {
    fill: none;
    stroke: color-mix(in srgb, currentColor 18%, transparent);
    stroke-linecap: round;
    opacity: 0;
    transition: opacity 0.3s ease-out;
  }
  .prog-fill {
    fill: none;
    stroke: var(--color-accent-mint);
    stroke-linecap: round;
    stroke-dasharray: 138;
    stroke-dashoffset: 138;
    transition: stroke-dashoffset 1.3s cubic-bezier(0.22, 1, 0.36, 1) 0.1s;
  }
  .prog-check {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-dasharray: 26;
    stroke-dashoffset: 26;
    transition: stroke-dashoffset 0.55s cubic-bezier(0.22, 1, 0.36, 1) 1.1s;
  }
  :global(.stat[data-in-view="true"]) .prog-bg {
    opacity: 1;
  }
  :global(.stat[data-in-view="true"]) .prog-fill {
    stroke-dashoffset: 1.4; /* ~99% of circumference ≈ 138 */
  }
  :global(.stat[data-in-view="true"]) .prog-check {
    stroke-dashoffset: 0;
  }

  /* ———— Scene: biometric (face with scan mesh + sweeping scan line) ———— */
  .bio-face {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
    stroke-dasharray: 140;
    stroke-dashoffset: 140;
    opacity: 0;
    transition:
      stroke-dashoffset 1s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.3s ease-out;
  }
  .bio-dot {
    fill: currentColor;
    opacity: 0;
    transform-origin: center;
    transform: scale(0.4);
    transition:
      opacity 0.3s ease-out,
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .bio-scan {
    stroke: var(--color-accent-mint);
    stroke-width: 1.4;
    stroke-linecap: round;
    opacity: 0;
  }
  :global(.stat[data-in-view="true"]) .bio-face {
    stroke-dashoffset: 0;
    opacity: 1;
  }
  :global(.stat[data-in-view="true"]) .bio-d-1 { opacity: 1; transform: scale(1); transition-delay: 0.5s; }
  :global(.stat[data-in-view="true"]) .bio-d-2 { opacity: 1; transform: scale(1); transition-delay: 0.6s; }
  :global(.stat[data-in-view="true"]) .bio-d-3 { opacity: 1; transform: scale(1); transition-delay: 0.7s; }
  :global(.stat[data-in-view="true"]) .bio-d-4 { opacity: 1; transform: scale(1); transition-delay: 0.8s; }
  :global(.stat[data-in-view="true"]) .bio-d-5 { opacity: 1; transform: scale(1); transition-delay: 0.9s; }
  :global(.stat[data-in-view="true"]) .bio-d-6 { opacity: 1; transform: scale(1); transition-delay: 1s; }
  :global(.stat[data-in-view="true"]) .bio-d-7 { opacity: 1; transform: scale(1); transition-delay: 1.1s; }

  @keyframes bio-sweep {
    0% { transform: translateY(-14px); opacity: 0; }
    15% { opacity: 1; }
    50% { transform: translateY(14px); opacity: 1; }
    85% { opacity: 0; }
    100% { transform: translateY(14px); opacity: 0; }
  }
  :global(.stat[data-in-view="true"]) .bio-scan {
    animation: bio-sweep 2.8s ease-in-out infinite 1.3s;
  }

  /* ———— Scene: certified (medal with ribbon + check) ———— */
  .cert-ribbon {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
    stroke-linejoin: round;
    stroke-dasharray: 120;
    stroke-dashoffset: 120;
    opacity: 0;
    transition:
      stroke-dashoffset 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.3s,
      opacity 0.3s ease-out 0.3s;
  }
  .cert-medal {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
    opacity: 0;
    transform-origin: 60px 34px;
    transform: scale(0.6);
    transition:
      opacity 0.35s ease-out,
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .cert-inner {
    fill: var(--color-accent-mint);
    opacity: 0;
    transform-origin: 60px 34px;
    transform: scale(0.4);
    transition:
      opacity 0.35s ease-out 0.25s,
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1) 0.25s;
  }
  .cert-check {
    fill: none;
    stroke: var(--color-ink);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-dasharray: 26;
    stroke-dashoffset: 26;
    transition: stroke-dashoffset 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0.8s;
  }
  :global(.stat[data-in-view="true"]) .cert-medal {
    opacity: 1;
    transform: scale(1);
  }
  :global(.stat[data-in-view="true"]) .cert-inner {
    opacity: 1;
    transform: scale(1);
  }
  :global(.stat[data-in-view="true"]) .cert-ribbon {
    stroke-dashoffset: 0;
    opacity: 1;
  }
  :global(.stat[data-in-view="true"]) .cert-check {
    stroke-dashoffset: 0;
  }
  @keyframes cert-glow {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.06); }
  }
  :global(.stat[data-in-view="true"]) .cert-inner {
    animation: cert-glow 2.8s ease-in-out infinite 1.5s;
  }

  /* ———— Scene: signed-growth (document + signature draw + upward arrow) ———— */
  .sg-doc,
  .sg-fold {
    stroke: currentColor;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.45s ease-out,
      transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .sg-ruled {
    stroke: color-mix(in srgb, currentColor 32%, transparent);
    opacity: 0;
    transition: opacity 0.4s ease-out 0.45s;
  }
  .sg-sig {
    stroke: var(--color-accent-mint);
    stroke-dasharray: 90;
    stroke-dashoffset: 90;
    opacity: 0;
    transition:
      stroke-dashoffset 1.05s cubic-bezier(0.22, 1, 0.36, 1) 0.7s,
      opacity 0.3s ease-out 0.7s;
  }
  .sg-arrow {
    stroke: var(--color-accent-mint);
    stroke-dasharray: 28;
    stroke-dashoffset: 28;
    opacity: 0;
    transform-origin: 93px 54px;
    transition:
      stroke-dashoffset 0.55s cubic-bezier(0.22, 1, 0.36, 1) 1.55s,
      opacity 0.3s ease-out 1.55s;
  }
  :global(.stat[data-in-view="true"]) .sg-doc,
  :global(.stat[data-in-view="true"]) .sg-fold {
    opacity: 1;
    transform: translateY(0);
  }
  :global(.stat[data-in-view="true"]) .sg-ruled {
    opacity: 1;
  }
  :global(.stat[data-in-view="true"]) .sg-sig {
    stroke-dashoffset: 0;
    opacity: 1;
  }
  :global(.stat[data-in-view="true"]) .sg-arrow {
    stroke-dashoffset: 0;
    opacity: 1;
    animation: sg-arrow-float 2.4s ease-in-out infinite 2.2s;
  }
  @keyframes sg-arrow-float {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(2px, -2px); }
  }

  /* ———— Scene: sprint (stopwatch gauge with sweeping needle) ———— */
  .sprint-body,
  .sprint-crown,
  .sprint-stem {
    stroke: currentColor;
    fill: none;
    stroke-dasharray: 180;
    stroke-dashoffset: 180;
    opacity: 0;
    transition:
      stroke-dashoffset 0.9s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.3s ease-out;
  }
  .sprint-crown {
    fill: currentColor;
    stroke: none;
  }
  .sprint-tick {
    stroke: currentColor;
    opacity: 0;
    transition: opacity 0.3s ease-out;
  }
  .sprint-needle {
    stroke: var(--color-accent-mint);
    transform-origin: 60px 44px;
    transform: rotate(-110deg);
    opacity: 0;
    transition:
      transform 1.2s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.3s ease-out;
  }
  .sprint-pivot {
    fill: var(--color-accent-mint);
    opacity: 0;
    transform-origin: 60px 44px;
    transform: scale(0);
    transition:
      opacity 0.35s ease-out,
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  :global(.stat[data-in-view="true"]) .sprint-body,
  :global(.stat[data-in-view="true"]) .sprint-crown,
  :global(.stat[data-in-view="true"]) .sprint-stem {
    stroke-dashoffset: 0;
    opacity: 1;
  }
  :global(.stat[data-in-view="true"]) .sprint-tick {
    opacity: 0.6;
    transition-delay: 0.5s;
  }
  :global(.stat[data-in-view="true"]) .sprint-needle {
    transform: rotate(45deg);
    opacity: 1;
    transition-delay: 0.6s;
  }
  :global(.stat[data-in-view="true"]) .sprint-pivot {
    opacity: 1;
    transform: scale(1);
    transition-delay: 0.9s;
    animation: sprint-pulse 2s ease-in-out infinite 1.8s;
  }
  @keyframes sprint-pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.25); }
  }

  /* ———— Scene: unify (six cells connected into one system) ———— */
  .uni-cell {
    stroke: currentColor;
    fill: none;
    stroke-width: 1.5;
    opacity: 0;
    transform-origin: center;
    transform: scale(0.7);
    transition:
      opacity 0.4s ease-out,
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .uni-link {
    stroke: var(--color-accent-mint);
    stroke-dasharray: 130;
    stroke-dashoffset: 130;
    opacity: 0;
    transition:
      stroke-dashoffset 1s cubic-bezier(0.22, 1, 0.36, 1) 0.8s,
      opacity 0.3s ease-out 0.8s;
  }
  :global(.stat[data-in-view="true"]) .uni-cell {
    opacity: 1;
    transform: scale(1);
  }
  :global(.stat[data-in-view="true"]) .uni-c-1 { transition-delay: 0.05s; }
  :global(.stat[data-in-view="true"]) .uni-c-2 { transition-delay: 0.15s; }
  :global(.stat[data-in-view="true"]) .uni-c-3 { transition-delay: 0.25s; }
  :global(.stat[data-in-view="true"]) .uni-c-4 { transition-delay: 0.35s; }
  :global(.stat[data-in-view="true"]) .uni-c-5 { transition-delay: 0.45s; }
  :global(.stat[data-in-view="true"]) .uni-c-6 { transition-delay: 0.55s; }
  :global(.stat[data-in-view="true"]) .uni-link {
    stroke-dashoffset: 0;
    opacity: 1;
  }

  /* ———— Scene: flow (JTBD optimization — winding path → direct path + check) ———— */
  .flow-long {
    stroke: color-mix(in srgb, currentColor 45%, transparent);
    stroke-dasharray: 3 3;
    opacity: 0;
    transition: opacity 0.5s ease-out 0.1s;
  }
  .flow-short {
    stroke: var(--color-accent-mint);
    stroke-dasharray: 70;
    stroke-dashoffset: 70;
    opacity: 0;
    transition:
      stroke-dashoffset 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.6s,
      opacity 0.3s ease-out 0.6s;
  }
  .flow-node {
    fill: currentColor;
    opacity: 0;
    transform-origin: center;
    transform: scale(0.3);
    transition:
      opacity 0.3s ease-out,
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .flow-check {
    stroke: var(--color-accent-mint);
    stroke-dasharray: 30;
    stroke-dashoffset: 30;
    opacity: 0;
    transition:
      stroke-dashoffset 0.5s cubic-bezier(0.22, 1, 0.36, 1) 1.5s,
      opacity 0.3s ease-out 1.5s;
  }
  :global(.stat[data-in-view="true"]) .flow-long {
    opacity: 1;
  }
  :global(.stat[data-in-view="true"]) .flow-short {
    stroke-dashoffset: 0;
    opacity: 1;
  }
  :global(.stat[data-in-view="true"]) .flow-node {
    opacity: 1;
    transform: scale(1);
  }
  :global(.stat[data-in-view="true"]) .flow-n-1 { transition-delay: 0.2s; }
  :global(.stat[data-in-view="true"]) .flow-n-2 { transition-delay: 0.3s; }
  :global(.stat[data-in-view="true"]) .flow-n-3 { transition-delay: 0.4s; }
  :global(.stat[data-in-view="true"]) .flow-check {
    stroke-dashoffset: 0;
    opacity: 1;
  }

  /* ———— Scene: reactivate (chat bubble + typing dots + mint pulse) ———— */
  .react-bubble {
    stroke: currentColor;
    stroke-dasharray: 180;
    stroke-dashoffset: 180;
    opacity: 0;
    transition:
      stroke-dashoffset 1s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.35s ease-out;
  }
  .react-dot {
    fill: currentColor;
    opacity: 0;
    transform-origin: center;
    transition: opacity 0.3s ease-out;
  }
  .react-pulse {
    fill: var(--color-accent-mint);
    opacity: 0;
    transform-origin: 80px 26px;
    transform: scale(0);
    transition:
      opacity 0.3s ease-out,
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .react-ring {
    stroke: var(--color-accent-mint);
    opacity: 0;
    transform-origin: 80px 26px;
    transform: scale(1);
  }
  :global(.stat[data-in-view="true"]) .react-bubble {
    stroke-dashoffset: 0;
    opacity: 1;
  }
  :global(.stat[data-in-view="true"]) .react-dot {
    opacity: 1;
    transition-delay: 0.5s;
  }
  :global(.stat[data-in-view="true"]) .react-pulse {
    opacity: 1;
    transform: scale(1);
    transition-delay: 0.8s;
    animation: react-pulse-beat 2s ease-in-out infinite 1.6s;
  }
  :global(.stat[data-in-view="true"]) .react-ring {
    animation: react-ring-expand 2s ease-out infinite 1.8s;
  }
  :global(.stat[data-in-view="true"]) .react-d-1 {
    animation: react-dot-bounce 1.4s ease-in-out infinite 1.2s;
  }
  :global(.stat[data-in-view="true"]) .react-d-2 {
    animation: react-dot-bounce 1.4s ease-in-out infinite 1.35s;
  }
  :global(.stat[data-in-view="true"]) .react-d-3 {
    animation: react-dot-bounce 1.4s ease-in-out infinite 1.5s;
  }
  @keyframes react-dot-bounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 1; }
    30% { transform: translateY(-3px); opacity: 0.7; }
  }
  @keyframes react-pulse-beat {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.2); }
  }
  @keyframes react-ring-expand {
    0% { transform: scale(1); opacity: 0.75; }
    100% { transform: scale(3); opacity: 0; }
  }

  /* ———— Scene: love (heart + sparkles) ———— */
  .love-heart {
    fill: var(--color-accent-mint);
    stroke: var(--color-ink);
    stroke-width: 1.3;
    stroke-linejoin: round;
    opacity: 0;
    transform-origin: 60px 42px;
    transform: scale(0.4);
    transition:
      opacity 0.4s ease-out,
      transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .love-spark {
    fill: var(--color-accent-mint);
    opacity: 0;
    transform-origin: center;
    transform: scale(0.4);
    transition:
      opacity 0.4s ease-out,
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  :global(.stat[data-in-view="true"]) .love-heart {
    opacity: 1;
    transform: scale(1);
    transition-delay: 0.05s;
    animation: love-beat 2.4s ease-in-out infinite 1.4s;
  }
  :global(.stat[data-in-view="true"]) .love-s-1 { opacity: 1; transform: scale(1); transition-delay: 0.6s; }
  :global(.stat[data-in-view="true"]) .love-s-2 { opacity: 1; transform: scale(1); transition-delay: 0.72s; }
  :global(.stat[data-in-view="true"]) .love-s-3 { opacity: 1; transform: scale(1); transition-delay: 0.84s; }
  :global(.stat[data-in-view="true"]) .love-s-4 { opacity: 1; transform: scale(1); transition-delay: 0.96s; }
  :global(.stat[data-in-view="true"]) .love-s-5 { opacity: 1; transform: scale(1); transition-delay: 1.08s; }
  :global(.stat[data-in-view="true"]) .love-s-6 { opacity: 1; transform: scale(1); transition-delay: 1.2s; }

  @keyframes love-beat {
    0%, 100% { transform: scale(1); }
    18% { transform: scale(1.14); }
    30% { transform: scale(1); }
    45% { transform: scale(1.1); }
  }

  /* ———— Scene: audience (overlapping user silhouettes + "+N") ———— */
  .av {
    opacity: 0;
    transform: translateY(8px) scale(0.9);
    transform-origin: center 48px;
    transition:
      opacity 0.4s ease-out,
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .av-head {
    fill: currentColor;
  }
  .av-body {
    fill: currentColor;
  }
  .av-plus-bg {
    fill: var(--color-accent-mint);
  }
  .av-plus-icon {
    stroke: var(--color-ink);
    stroke-width: 1.6;
    stroke-linecap: round;
    fill: none;
  }
  :global(.stat[data-in-view="true"]) .av-1 {
    opacity: 1;
    transform: translateY(0) scale(1);
    transition-delay: 0.05s;
  }
  :global(.stat[data-in-view="true"]) .av-2 {
    opacity: 1;
    transform: translateY(0) scale(1);
    transition-delay: 0.2s;
  }
  :global(.stat[data-in-view="true"]) .av-3 {
    opacity: 1;
    transform: translateY(0) scale(1);
    transition-delay: 0.35s;
  }
  :global(.stat[data-in-view="true"]) .av-4 {
    opacity: 1;
    transform: translateY(0) scale(1);
    transition-delay: 0.5s;
  }
  :global(.stat[data-in-view="true"]) .av-plus {
    opacity: 1;
    transform: translateY(0) scale(1);
    transition-delay: 0.7s;
  }

  /* Ambient — the "+" badge gently pulses once loaded */
  @keyframes av-plus-pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.12); }
  }
  :global(.stat[data-in-view="true"]) .av-plus {
    transform-origin: 104px 38px;
  }
  :global(.stat[data-in-view="true"]) .av-plus .av-plus-bg {
    transform-origin: 104px 38px;
    animation: av-plus-pulse 2.8s ease-in-out infinite 1.2s;
  }
  :global(.stat):hover .av-1 { transform: translateY(-2px); }
  :global(.stat):hover .av-2 { transform: translateY(-2px); transition-delay: 40ms; }
  :global(.stat):hover .av-3 { transform: translateY(-2px); transition-delay: 80ms; }
  :global(.stat):hover .av-4 { transform: translateY(-2px); transition-delay: 120ms; }
  :global(.stat):hover .av-plus .av-plus-bg {
    animation-duration: 1.2s;
  }

  /* ———— Scene: streak (8-week sustained growth — bars + trendline + tip) ———— */
  .streak-base {
    stroke: color-mix(in srgb, currentColor 40%, transparent);
    fill: none;
    opacity: 0;
    transition: opacity 0.4s ease-out 0.1s;
  }
  .streak-bar {
    fill: color-mix(in srgb, currentColor 14%, transparent);
    transform-origin: center bottom;
    transform: scaleY(0);
    transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .streak-bar-hi {
    fill: color-mix(in srgb, var(--color-accent-mint) 80%, transparent);
  }
  .streak-trend {
    stroke: var(--color-accent-mint);
    stroke-dasharray: 140;
    stroke-dashoffset: 140;
    opacity: 0;
    transition:
      stroke-dashoffset 1.1s cubic-bezier(0.22, 1, 0.36, 1) 0.9s,
      opacity 0.3s ease-out 0.9s;
  }
  .streak-tip {
    fill: var(--color-accent-mint);
    opacity: 0;
    transform-origin: 97px 16px;
    transform: scale(0.4);
    transition:
      opacity 0.3s ease-out 1.9s,
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1) 1.9s;
  }
  :global(.stat[data-in-view="true"]) .streak-base { opacity: 1; }
  :global(.stat[data-in-view="true"]) .streak-bar { transform: scaleY(1); }
  :global(.stat[data-in-view="true"]) .streak-b-1 { transition-delay: 0.1s; }
  :global(.stat[data-in-view="true"]) .streak-b-2 { transition-delay: 0.18s; }
  :global(.stat[data-in-view="true"]) .streak-b-3 { transition-delay: 0.26s; }
  :global(.stat[data-in-view="true"]) .streak-b-4 { transition-delay: 0.34s; }
  :global(.stat[data-in-view="true"]) .streak-b-5 { transition-delay: 0.42s; }
  :global(.stat[data-in-view="true"]) .streak-b-6 { transition-delay: 0.5s; }
  :global(.stat[data-in-view="true"]) .streak-b-7 { transition-delay: 0.58s; }
  :global(.stat[data-in-view="true"]) .streak-b-8 { transition-delay: 0.66s; }
  :global(.stat[data-in-view="true"]) .streak-trend { stroke-dashoffset: 0; opacity: 1; }
  :global(.stat[data-in-view="true"]) .streak-tip {
    opacity: 1;
    transform: scale(1);
    animation: streak-tip-pulse 1.8s ease-in-out infinite 2.1s;
  }
  @keyframes streak-tip-pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.3); }
  }

  /* ———— Scene: orbit (retained users held in orbit around a central core) ———— */
  .orbit-ring {
    stroke: color-mix(in srgb, currentColor 40%, transparent);
    fill: none;
    opacity: 0;
    transform-origin: 60px 40px;
    transform: scale(0.7);
    transition:
      opacity 0.45s ease-out,
      transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .orbit-core {
    fill: var(--color-accent-mint);
    opacity: 0;
    transform-origin: 60px 40px;
    transform: scale(0.3);
    transition:
      opacity 0.4s ease-out,
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .orbit-pulse {
    stroke: var(--color-accent-mint);
    fill: none;
    opacity: 0;
    transform-origin: 60px 40px;
  }
  .orbit-node {
    fill: currentColor;
    opacity: 0;
    transform-origin: 60px 40px;
    transform: scale(0);
    transition:
      opacity 0.4s ease-out,
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }
  :global(.stat[data-in-view="true"]) .orbit-ring-outer {
    opacity: 1;
    transform: scale(1);
    transition-delay: 0.1s;
  }
  :global(.stat[data-in-view="true"]) .orbit-ring-inner {
    opacity: 1;
    transform: scale(1);
    transition-delay: 0.25s;
  }
  :global(.stat[data-in-view="true"]) .orbit-core {
    opacity: 1;
    transform: scale(1);
    transition-delay: 0.4s;
  }
  :global(.stat[data-in-view="true"]) .orbit-n-1 { opacity: 1; transform: scale(1); transition-delay: 0.6s; }
  :global(.stat[data-in-view="true"]) .orbit-n-2 { opacity: 1; transform: scale(1); transition-delay: 0.72s; }
  :global(.stat[data-in-view="true"]) .orbit-n-3 { opacity: 1; transform: scale(1); transition-delay: 0.84s; }
  :global(.stat[data-in-view="true"]) .orbit-n-4 { opacity: 1; transform: scale(1); transition-delay: 0.96s; }
  :global(.stat[data-in-view="true"]) .orbit-pulse {
    animation: orbit-pulse-beat 2.6s ease-out infinite 1.4s;
  }
  @keyframes orbit-pulse-beat {
    0% { transform: scale(0.7); opacity: 0.6; }
    100% { transform: scale(2.2); opacity: 0; }
  }
  :global(.stat):hover .orbit-ring-outer {
    animation: orbit-spin 6s linear infinite;
  }
  :global(.stat):hover .orbit-ring-inner {
    animation: orbit-spin 4s linear infinite reverse;
  }
  @keyframes orbit-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* ———— Scene: sync (Apple Watch + Strava device linked) ———— */
  .sync-device,
  .sync-face {
    stroke: currentColor;
    fill: none;
    opacity: 0;
    transform-origin: center;
    transform: translateY(6px);
    transition:
