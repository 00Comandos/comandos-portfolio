---
import type { FeatureGridItem } from "~/data/case-studies/types";

type Props = {
  columns: 2 | 3;
  items: readonly FeatureGridItem[];
};

const { columns, items } = Astro.props;
const gridCols = columns === 3 ? "md:grid-cols-3" : "md:grid-cols-2";
---

<ol
  class:list={[
    "feature-grid not-prose grid gap-4 md:gap-0",
    gridCols,
  ]}
>
  {
    items.map((item) => (
      <li
        class:list={[
          "feature-grid-cell p-5 md:p-6",
          item.highlight ? "is-highlight" : "",
        ]}
      >
        <span class="block text-[0.95rem] text-[color:var(--color-muted)] leading-none">
          {item.number}
        </span>
        {item.label && (
          <p class="mt-3 text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-[color:var(--color-muted)]">
            {item.label}
          </p>
        )}
        <h4 class="mt-2 text-[1.05rem] md:text-[1.125rem] font-bold tracking-tight leading-[1.3]">
          {item.title}
        </h4>
        <p class="mt-3 text-[0.9375rem] leading-[1.55] text-[color:var(--color-ink-soft)]">
          {item.body}
        </p>
      </li>
    ))
  }
</ol>

<style>
  .feature-grid {
    counter-reset: none;
    list-style: none;
    padding: 0;
    margin-block: 1.25rem;
  }
  @media (min-width: 768px) {
    .feature-grid {
      margin-block: 2rem;
    }
  }
  .feature-grid-cell {
    background-color: var(--color-paper-soft);
    border-radius: var(--radius-md);
  }
  @media (min-width: 768px) {
    .feature-grid {
      gap: 0;
      background-color: var(--color-paper-soft);
      border-radius: var(--radius-md);
      overflow: hidden;
    }
    .feature-grid-cell {
      border-radius: 0;
      background-color: transparent;
    }
    .feature-grid-cell + .feature-grid-cell {
      border-left: 1px solid var(--color-border);
    }
    .feature-grid-cell.is-highlight {
      background-color: var(--color-paper);
      box-shadow: inset 0 0 0 1px var(--color-border);
      border-radius: var(--radius-md);
    }
  }
</style>
