---
import SectionChip from "~/components/case-study/SectionChip.astro";
import ContentImage from "~/components/case-study/ContentImage.astro";
import Divider from "~/components/case-study/Divider.astro";
import Checklist from "~/components/case-study/Checklist.astro";
import FeatureGrid from "~/components/case-study/FeatureGrid.astro";
import TwoColMedia from "~/components/case-study/TwoColMedia.astro";
import ResponsiveMedia from "~/components/case-study/ResponsiveMedia.astro";
import ProseWithImage from "~/components/case-study/ProseWithImage.astro";
import type { CaseStudyContent } from "~/data/case-studies/types";

type Props = { content: CaseStudyContent["adventure"] };
const { content } = Astro.props;
---

<section id="adventure" class="pt-20 md:pt-28 pb-8 md:pb-10">
  <div class="cs-body">
    <SectionChip variant="adventure" label="Adventure" />

    <h2 class="mt-6 text-[1.75rem] md:text-[2.25rem] font-extrabold leading-[1.1] tracking-tight">
      {content.heading}
    </h2>

    <div class="adventure-blocks mt-10 space-y-8">
      {
        content.blocks.map((block) => {
          if (block.kind === "divider") return <Divider variant={block.variant ?? "hatched"} />;
          if (block.kind === "intro") {
            return (
              <p class="text-[1rem] leading-[1.7] text-[color:var(--color-ink-soft)]">
                {block.text}
              </p>
            );
          }
          if (block.kind === "caption") {
            return (
              <p class="text-center text-[0.95rem] leading-[1.65] text-[color:var(--color-muted)] max-w-xl mx-auto pb-6 md:pb-10">
                {block.text}
              </p>
            );
          }
          if (block.kind === "image") {
            return <ContentImage image={block.image} rounded={block.rounded === true} />;
          }
          if (block.kind === "chip") {
            return (
              <div data-chip="true">
                <SectionChip variant={block.icon} label={block.label} />
              </div>
            );
          }
          if (block.kind === "feature-grid") {
            return <FeatureGrid columns={block.columns} items={block.items} />;
          }
          if (block.kind === "heading") {
            return (
              <div data-heading="true">
                {block.label && (
                  <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[color:var(--color-muted)]">
                    {block.label}
                  </p>
                )}
                <h3 class="mt-2 text-xl md:text-[1.625rem] font-bold tracking-tight leading-[1.2]">
                  {block.heading}
                </h3>
                {block.body && (
                  <p class="mt-3 text-[1rem] leading-[1.7] text-[color:var(--color-ink-soft)]">
                    {block.body}
                  </p>
                )}
              </div>
            );
          }
          if (block.kind === "two-col-media") {
            return <TwoColMedia items={block.items} />;
          }
          if (block.kind === "responsive-media") {
            return <ResponsiveMedia desktop={block.desktop} mobile={block.mobile} />;
          }
          if (block.kind === "prose-with-image") {
            return (
              <ProseWithImage
                heading={block.heading}
                body={block.body}
                image={block.image}
                imagePosition={block.imagePosition}
              />
            );
          }
          if (block.kind === "callout") {
            return (
              <div class="text-center">
                {block.label && (
                  <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[color:var(--color-muted)]">
                    {block.label}
                  </p>
                )}
                <h3 class="mt-2 text-xl md:text-[1.625rem] font-bold tracking-tight leading-[1.2]">
                  {block.heading}
                </h3>
                {block.image && (
                  <div class="mt-8">
                    <ContentImage image={block.image} />
                  </div>
                )}
              </div>
            );
          }
          if (block.kind === "checklist") {
            return <Checklist items={block.items} />;
          }
          if (block.kind === "step") {
            return (
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[color:var(--color-muted)]">
                  {block.step}
                </p>
                <h3 class="mt-2 text-xl md:text-[1.625rem] font-bold tracking-tight leading-[1.2]">
                  {block.heading}
                </h3>
                {block.body && (
                  <p class="mt-3 text-[1rem] leading-[1.7] text-[color:var(--color-ink-soft)]">
                    {block.body}
                  </p>
                )}
                {block.image && (
                  <div class="mt-6">
                    <ContentImage image={block.image} />
                  </div>
                )}
                {block.tail && (
                  <div class="mt-6">
                    <Checklist items={block.tail} />
                  </div>
                )}
              </div>
            );
          }
          return null;
        })
      }
    </div>
  </div>
</section>

<style>
  /* Tight chip → next-block pairing so the chip reads as a lead-in.
     Headings keep regular spacing so images below them can breathe. */
  .adventure-blocks > [data-chip] {
    margin-block-end: 0.5rem !important;
  }
</style>
