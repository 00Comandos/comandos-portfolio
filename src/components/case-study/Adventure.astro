---
import SectionChip from "~/components/case-study/SectionChip.astro";
import ContentImage from "~/components/case-study/ContentImage.astro";
import Divider from "~/components/case-study/Divider.astro";
import Checklist from "~/components/case-study/Checklist.astro";
import FeatureGrid from "~/components/case-study/FeatureGrid.astro";
import TwoColMedia from "~/components/case-study/TwoColMedia.astro";
import ResponsiveMedia from "~/components/case-study/ResponsiveMedia.astro";
import ImageGrid from "~/components/case-study/ImageGrid.astro";
import ProseWithImage from "~/components/case-study/ProseWithImage.astro";
import StatIllustration from "~/components/case-study/StatIllustration.astro";
import AnimatedIcon from "~/components/case-study/AnimatedIcon.astro";
import type { CaseStudyContent } from "~/data/case-studies/types";

type IconMotion = "breathe" | "rock" | "bounce" | "scan" | "none";
const motionFor = (name?: string): IconMotion => {
  if (!name) return "breathe";
  if (name.includes("scan")) return "scan";
  if (name.includes("gauge") || name.includes("activity")) return "rock";
  if (name.includes("message")) return "bounce";
  return "breathe";
};

// Render body copy that supports \n\n paragraph breaks and **bold** emphasis.
// HTML-escapes first, then swaps in <strong> — keeps the surface minimal.
const escape = (s: string) =>
  s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
const renderProse = (body: string) =>
  body
    .split(/\n{2,}/)
    .map(
      (p) =>
        `<p class="mt-3 text-[1rem] leading-[1.7] text-[color:var(--color-ink-soft)]">${escape(
          p,
        ).replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")}</p>`,
    )
    .join("");

type Props = { content: CaseStudyContent["adventure"] };
const { content } = Astro.props;
---

<section id="adventure" class="pt-20 md:pt-28 pb-8 md:pb-10">
  <div class="cs-body">
    <SectionChip variant="adventure" label="Adventure" />

    <h2 class="display-serif mt-6 text-[2.25rem] md:text-[3rem]">
      {content.heading}
    </h2>

    <div class="adventure-blocks mt-10 space-y-8">
      {
        content.blocks.map((block) => {
          if (block.kind === "divider") return <Divider variant={block.variant ?? "hatched"} />;
          if (block.kind === "spacer") {
            const h =
              block.size === "lg"
                ? "h-10 md:h-14"
                : block.size === "sm"
                  ? "h-3 md:h-4"
                  : "h-6 md:h-9";
            return <div class:list={["block", h]} aria-hidden="true" />;
          }
          if (block.kind === "intro") {
            return (
              <p class="text-[1rem] leading-[1.7] text-[color:var(--color-ink-soft)]">
                {block.text}
              </p>
            );
          }
          if (block.kind === "caption") {
            return (
              <p class="text-center text-[0.95rem] leading-[1.65] text-[color:var(--color-muted)] max-w-xl mx-auto pb-6 md:pb-10">
                {block.text}
              </p>
            );
          }
          if (block.kind === "image") {
            return <ContentImage image={block.image} rounded={block.rounded === true} />;
          }
          if (block.kind === "chip") {
            return (
              <div data-chip="true">
                <SectionChip variant={block.icon} label={block.label} />
              </div>
            );
          }
          if (block.kind === "feature-grid") {
            return <FeatureGrid columns={block.columns} items={block.items} />;
          }
          if (block.kind === "heading") {
            return (
              <div data-heading="true">
                {block.label && (
                  <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[color:var(--color-muted)]">
                    {block.label}
                  </p>
                )}
                <h3 class="display-serif mt-2 text-[2rem] md:text-[2.375rem]">
                  {block.heading}
                </h3>
                {block.body && <Fragment set:html={renderProse(block.body)} />}
              </div>
            );
          }
          if (block.kind === "two-col-media") {
            return <TwoColMedia items={block.items} />;
          }
          if (block.kind === "responsive-media") {
            return <ResponsiveMedia desktop={block.desktop} mobile={block.mobile} />;
          }
          if (block.kind === "image-grid") {
            return <ImageGrid columns={block.columns} images={block.images} />;
          }
          if (block.kind === "prose-with-image") {
            return (
              <ProseWithImage
                heading={block.heading}
                body={block.body}
                image={block.image}
                imagePosition={block.imagePosition}
              />
            );
          }
          if (block.kind === "illustrated-heading") {
            return (
              <div data-adventure-stat data-in-view="false">
                {block.icon ? (
                  <AnimatedIcon name={block.icon} motion={motionFor(block.icon)} />
                ) : block.scene ? (
                  <div class="stat inline-block">
                    <StatIllustration scene={block.scene} />
                  </div>
                ) : null}
                <h3 class="display-serif mt-4 text-[2rem] md:text-[2.375rem]">
                  {block.heading}
                </h3>
                {block.body && (
                  <p class="mt-3 text-[1rem] leading-[1.7] text-[color:var(--color-ink-soft)]">
                    {block.body}
                  </p>
                )}
              </div>
            );
          }
          if (block.kind === "illustrated-groups") {
            const cols = block.groups.length === 2 ? "md:grid-cols-2" : "md:grid-cols-3";
            return (
              <div data-adventure-stat data-in-view="false">
                <div class:list={["grid gap-10", cols, "md:gap-10"]}>
                  {block.groups.map((g) => (
                    <div>
                      {g.icon ? (
                        <AnimatedIcon name={g.icon} motion={motionFor(g.icon)} />
                      ) : g.scene ? (
                        <div class="stat inline-block">
                          <StatIllustration scene={g.scene} />
                        </div>
                      ) : null}
                      <h4 class="mt-4 text-[1.125rem] md:text-[1.25rem] font-bold tracking-tight leading-[1.2]">
                        {g.heading}
                      </h4>
                      <div class="mt-4">
                        <Checklist items={g.items} />
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            );
          }
          if (block.kind === "callout") {
            return (
              <div class="text-center">
                {block.label && (
                  <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[color:var(--color-muted)]">
                    {block.label}
                  </p>
                )}
                <h3 class="display-serif mt-2 text-[2rem] md:text-[2.375rem]">
                  {block.heading}
                </h3>
                {block.image && (
                  <div class="mt-8">
                    <ContentImage image={block.image} />
                  </div>
                )}
              </div>
            );
          }
          if (block.kind === "checklist") {
            return <Checklist items={block.items} />;
          }
          if (block.kind === "step") {
            return (
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[color:var(--color-muted)]">
                  {block.step}
                </p>
                <h3 class="display-serif mt-2 text-[2rem] md:text-[2.375rem]">
                  {block.heading}
                </h3>
                {block.body && <Fragment set:html={renderProse(block.body)} />}
                {block.image && (
                  <div class="mt-6">
                    <ContentImage image={block.image} />
                  </div>
                )}
                {block.tail && (
                  <div class="mt-6">
                    <Checklist items={block.tail} />
                  </div>
                )}
              </div>
            );
          }
          return null;
        })
      }
    </div>
  </div>
</section>

<style>
  /* Tight chip → next-block pairing so the chip reads as a lead-in.
     Headings keep regular spacing so images below them can breathe. */
  .adventure-blocks > [data-chip] {
    margin-block-end: 0.5rem !important;
  }
  /* Illustrated headings / groups are a new visual beat — give them
     real breathing room above so they don't feel glued to the imagery
     from the previous block. */
  .adventure-blocks > [data-adventure-stat] {
    margin-block-start: 3.5rem !important;
  }
  @media (min-width: 768px) {
    .adventure-blocks > [data-adventure-stat] {
      margin-block-start: 4.5rem !important;
    }
  }
</style>

<script>
  // Mark inline illustrations as in-view once they scroll into viewport so
  // their CSS animations (stroke-dashoffset, cascades, etc.) kick in.
  // Observes both the outer wrapper (for AnimatedIcon) and inner .stat
  // elements (for rich StatIllustration scenes).
  const wrappers = document.querySelectorAll<HTMLElement>(
    "[data-adventure-stat]",
  );
  const stats = document.querySelectorAll<HTMLElement>(
    "[data-adventure-stat] .stat",
  );
  const all: HTMLElement[] = [...wrappers, ...stats];
  if (all.length > 0) {
    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).setAttribute("data-in-view", "true");
            obs.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.3 },
    );
    all.forEach((el) => obs.observe(el));
  }
</script>
