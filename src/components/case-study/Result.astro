---
import { Image } from "astro:assets";
import Divider from "~/components/case-study/Divider.astro";
import type { CaseStudyContent, StatIcon } from "~/data/case-studies/types";

type Props = { content: CaseStudyContent["result"] };
const { content } = Astro.props;

const builtInIcon = (icon: Extract<StatIcon, string>): string => {
  switch (icon) {
    case "globe":
      return "🌐";
    case "money":
      return "💵";
    case "bell":
      return "🔔";
    case "chart":
      return "📈";
  }
};
---

<section id="result" class="pb-24">
  <div class="cs-body">
    <Divider />

    <h2 class="text-center text-[1.75rem] md:text-[2.25rem] font-extrabold leading-[1.1] tracking-tight">
      {content.heading}
    </h2>

    <dl class="mt-12 grid gap-10 md:grid-cols-3">
      {
        content.stats.map((s) => (
          <div class="flex flex-col items-start">
            {typeof s.icon === "string" ? (
              <div class="h-14 w-14 rounded-full bg-[color:var(--color-paper-warm)] flex items-center justify-center text-xl">
                <span aria-hidden="true">{builtInIcon(s.icon)}</span>
              </div>
            ) : (
              <Image
                src={s.icon.image}
                alt={s.icon.alt ?? ""}
                width={56}
                height={56}
                loading="lazy"
                decoding="async"
                class="h-14 w-14 object-contain"
              />
            )}
            <dt class="mt-4 text-[1.125rem] font-bold leading-tight">
              {s.value} {s.label}
            </dt>
            {s.caption && (
              <dd class="mt-2 text-sm text-[color:var(--color-muted)]">
                {s.caption}
              </dd>
            )}
          </div>
        ))
      }
    </dl>
  </div>
</section>
