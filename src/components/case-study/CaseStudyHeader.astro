---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import ContentImage from "~/components/case-study/ContentImage.astro";
import type { CaseStudyContent } from "~/data/case-studies/types";

type Props = {
  content: CaseStudyContent;
  fallbackImage: ImageMetadata;
  title: string;
};

const { content, fallbackImage, title } = Astro.props;

const introParagraphs = content.hero.intro.split(/\n\n+/);

// Shorten the title for the breadcrumb. Prefer the part before
// "Case Study:" when present; otherwise keep the full title.
const shortTitle = (() => {
  const idx = title.toLowerCase().indexOf("case study");
  if (idx > 0) return title.slice(0, idx).replace(/[:\s—-]+$/, "").trim();
  return title;
})();
---

<section class="pt-8 md:pt-12 pb-10">
  <div class="cs-body">
    <div class="flex flex-col items-start">
      {
        content.brandLogo?.kind === "public" && (
          <img
            src={content.brandLogo.src}
            alt={content.brandLogo.alt}
            height={content.brandLogo.height ?? 28}
            style={`height: ${content.brandLogo.height ?? 28}px; width: auto;`}
            class="mb-2"
            loading="eager"
            decoding="async"
          />
        )
      }
      <p class="text-sm text-[color:var(--color-muted)]">{content.kicker}</p>

      <h1 class="mt-6 text-[2rem] md:text-[2.75rem] font-extrabold leading-[1.05] tracking-tight">
        {title}
      </h1>

      <nav aria-label="Breadcrumb" class="mt-5 md:mt-6">
        <ol class="flex flex-wrap items-center gap-x-2 gap-y-1 text-[0.8125rem] text-[color:var(--color-muted)]">
          <li class="flex items-center">
            <a href="/" class="breadcrumb-link">Home</a>
          </li>
          <li aria-hidden="true" class="select-none">/</li>
          <li class="flex items-center">
            <a href="/projects" class="breadcrumb-link">Projects</a>
          </li>
          <li aria-hidden="true" class="select-none">/</li>
          <li aria-current="page" class="text-[color:var(--color-ink)] font-medium">
            {shortTitle}
          </li>
        </ol>
      </nav>
    </div>
  </div>

  <div class="cs-body mt-10">
    {
      content.hero.mobileStack && content.hero.mobileStack.length > 0 ? (
        <>
          <div class="hidden md:block">
            {content.hero.image ? (
              <ContentImage image={content.hero.image} priority />
            ) : (
              <Image
                src={fallbackImage}
                alt={title}
                widths={[640, 960, 1280, 1536]}
                sizes="(min-width: 768px) 720px, 100vw"
                loading="eager"
                decoding="async"
                class="w-full h-auto object-cover aspect-[16/10]"
              />
            )}
          </div>
          <div class="md:hidden space-y-4">
            {content.hero.mobileStack.map((img) => (
              <ContentImage image={img} priority />
            ))}
          </div>
        </>
      ) : content.hero.image ? (
        <ContentImage image={content.hero.image} priority />
      ) : (
        <div class="overflow-hidden bg-[color:var(--color-paper-soft)]">
          <Image
            src={fallbackImage}
            alt={title}
            widths={[640, 960, 1280, 1536]}
            sizes="(min-width: 768px) 720px, 100vw"
            loading="eager"
            decoding="async"
            class="w-full h-auto object-cover aspect-[16/10]"
          />
        </div>
      )
    }
  </div>

  <div class="cs-body mt-8">
    <div class="space-y-4 text-[1rem] leading-[1.7] text-[color:var(--color-ink-soft)]">
      {introParagraphs.map((p) => <p>{p}</p>)}
      {
        content.hero.bullets && content.hero.bullets.length > 0 && (
          <ul class="pl-5 space-y-1 list-disc marker:text-[color:var(--color-ink)]">
            {content.hero.bullets.map((b) => <li>{b}</li>)}
          </ul>
        )
      }
    </div>
  </div>
</section>

<style>
  .breadcrumb-link {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .breadcrumb-link:hover,
  .breadcrumb-link:focus-visible {
    color: var(--color-ink);
    border-bottom-color: var(--color-ink);
  }
</style>
