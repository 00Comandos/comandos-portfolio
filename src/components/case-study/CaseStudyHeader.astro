---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import ContentImage from "~/components/case-study/ContentImage.astro";
import ArrowIcon from "~/components/ui/ArrowIcon.astro";
import type { CaseStudyContent } from "~/data/case-studies/types";

type Props = {
  content: CaseStudyContent;
  fallbackImage: ImageMetadata;
  title: string;
  description: string;
  impact: string;
  timeline: string;
};

const { content, fallbackImage, title, description, impact, timeline } =
  Astro.props;

const introParagraphs = content.hero.intro.split(/\n\n+/);
---

<section class="pt-8 md:pt-12 pb-10">
  <div class="cs-body">
    <a href="/projects" class="btn-link mb-8 md:mb-10">
      <span class="rotate-180 inline-block"><ArrowIcon /></span>
      All projects
    </a>

    <div class="flex flex-col items-start">
      {
        content.brandLogo?.kind === "public" && (
          <img
            src={content.brandLogo.src}
            alt={content.brandLogo.alt}
            height={content.brandLogo.height ?? 28}
            style={`height: ${content.brandLogo.height ?? 28}px; width: auto;`}
            class="mb-3"
            loading="eager"
            decoding="async"
          />
        )
      }
      <p class="text-sm text-[color:var(--color-muted)]">{content.kicker}</p>

      <h1 class="display-serif mt-5 text-[2.5rem] md:text-[3.5rem] max-w-4xl">
        {title}
      </h1>

      <p class="mt-6 max-w-2xl text-[1.0625rem] md:text-[1.125rem] leading-[1.55] text-[color:var(--color-muted)]">
        {description}
      </p>

      <dl class="mt-8 flex flex-wrap gap-x-12 gap-y-4 text-sm">
        <div>
          <dt class="text-[color:var(--color-muted)] text-xs uppercase tracking-[0.14em] font-semibold">
            Impact
          </dt>
          <dd class="mt-2 text-base font-semibold text-[color:var(--color-ink)]">
            {impact}
          </dd>
        </div>
        <div>
          <dt class="text-[color:var(--color-muted)] text-xs uppercase tracking-[0.14em] font-semibold">
            Timeline
          </dt>
          <dd class="mt-2 text-base font-semibold text-[color:var(--color-ink)]">
            {timeline}
          </dd>
        </div>
      </dl>
    </div>
  </div>

  <div class="cs-body mt-10 md:mt-12">
    {
      content.hero.mobileStack && content.hero.mobileStack.length > 0 ? (
        <>
          <div class="hidden md:block">
            {content.hero.image ? (
              <ContentImage image={content.hero.image} priority />
            ) : (
              <Image
                src={fallbackImage}
                alt={title}
                widths={[640, 960, 1280, 1536]}
                sizes="(min-width: 768px) 720px, 100vw"
                loading="eager"
                decoding="async"
                class="w-full h-auto object-cover aspect-[16/10]"
              />
            )}
          </div>
          <div class="md:hidden space-y-4">
            {content.hero.mobileStack.map((img) => (
              <ContentImage image={img} priority />
            ))}
          </div>
        </>
      ) : content.hero.image ? (
        <ContentImage image={content.hero.image} priority />
      ) : (
        <div class="overflow-hidden bg-[color:var(--color-paper-soft)]">
          <Image
            src={fallbackImage}
            alt={title}
            widths={[640, 960, 1280, 1536]}
            sizes="(min-width: 768px) 720px, 100vw"
            loading="eager"
            decoding="async"
            class="w-full h-auto object-cover aspect-[16/10]"
          />
        </div>
      )
    }
  </div>

  <div class="cs-body mt-8">
    <div class="space-y-4 text-[1rem] leading-[1.7] text-[color:var(--color-ink-soft)]">
      {introParagraphs.map((p) => <p>{p}</p>)}
      {
        content.hero.bullets && content.hero.bullets.length > 0 && (
          <ul class="pl-5 space-y-1 list-disc marker:text-[color:var(--color-ink)]">
            {content.hero.bullets.map((b) => <li>{b}</li>)}
          </ul>
        )
      }
    </div>
  </div>
</section>
