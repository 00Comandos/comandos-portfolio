---
import { clients } from "~/data/clients";
---

<section aria-labelledby="clients-heading" class="py-14 md:py-20 bg-[color:var(--color-paper)]">
  <div class="container-page">
    <p id="clients-heading" class="text-center text-sm font-medium text-[color:var(--color-ink)]">
      We have impacted millions of users with
    </p>

    <ul class="mt-10 flex flex-wrap items-center justify-center gap-x-10 sm:gap-x-12 md:gap-x-16 gap-y-8">
      {
        clients.map((c) => (
          <li class="flex items-center justify-center h-10">
            {c.website ? (
              <a
                href={c.website}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={c.name}
                class="flex items-center justify-center h-10 grayscale opacity-80 hover:grayscale-0 hover:opacity-100 transition duration-200"
              >
                <img
                  src={c.logo}
                  alt={c.name}
                  loading="lazy"
                  decoding="async"
                  class="max-h-7 md:max-h-8 w-auto object-contain"
                />
              </a>
            ) : (
              <img
                src={c.logo}
                alt={c.name}
                loading="lazy"
                decoding="async"
                class="max-h-7 md:max-h-8 w-auto object-contain grayscale opacity-80 hover:grayscale-0 hover:opacity-100 transition duration-200"
              />
            )}
          </li>
        ))
      }
    </ul>
  </div>
</section>
