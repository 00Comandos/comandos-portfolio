---
// The Ascent Chart — hero illustration.
// A rising stepped ridgeline that reads simultaneously as a mountain range
// ("North Face Growth", "Seeing the mountain", "Making top") and as a growth
// chart ("Backed by Data"). Four waypoint dots along the ridge use the exact
// case-study chip palette (Challenge pink → Adventure mint → Worth mint →
// Result gold), so the hero's four dots rhyme with every case study below.
// A climber dot travels the ridge from base camp to summit, where a mint
// flag plants and pulses.
---

<div class="hero-illus" aria-hidden="true">
  <svg
    viewBox="0 0 480 280"
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    preserveAspectRatio="xMidYMid meet"
  >
    <line
      x1="20"
      y1="240"
      x2="460"
      y2="240"
      class="hi-baseline"
      stroke-width="1"
      stroke-dasharray="3 4"
      stroke-linecap="round"
    />
    <line x1="60" y1="238" x2="60" y2="244" class="hi-tick" stroke-width="1" />
    <line x1="160" y1="238" x2="160" y2="244" class="hi-tick" stroke-width="1" />
    <line x1="260" y1="238" x2="260" y2="244" class="hi-tick" stroke-width="1" />
    <line x1="360" y1="238" x2="360" y2="244" class="hi-tick" stroke-width="1" />

    <path
      d="M 30 230 L 75 210 L 120 180 L 155 200 L 210 140 L 250 160 L 300 100 L 335 120 L 430 40"
      class="hi-line"
      pathLength="100"
      stroke-width="2.4"
      stroke-linecap="round"
      stroke-linejoin="round"
    />

    <g transform="translate(120 180)">
      <g class="hi-wp hi-wp-1">
        <circle r="5.4" />
      </g>
    </g>
    <g transform="translate(210 140)">
      <g class="hi-wp hi-wp-2">
        <circle r="5.4" />
      </g>
    </g>
    <g transform="translate(300 100)">
      <g class="hi-wp hi-wp-3">
        <circle r="5.4" />
      </g>
    </g>

    <g transform="translate(430 40)">
      <circle r="16" class="hi-pulse" />
      <g class="hi-wp hi-wp-4">
        <circle r="6.2" />
      </g>
      <g class="hi-flag">
        <line
          x1="0"
          y1="0"
          x2="0"
          y2="-26"
          class="hi-flag-pole"
          stroke-width="1.6"
          stroke-linecap="round"
        />
        <path d="M0 -25 L16 -20 L0 -14 Z" class="hi-flag-cloth" />
      </g>
    </g>

    <g class="hi-climber">
      <circle r="4.2" class="hi-climber-dot" />
      <animateMotion
        begin="1.6s"
        dur="1.6s"
        calcMode="spline"
        keyTimes="0;1"
        keySplines="0.22 1 0.36 1"
        path="M 30 230 L 75 210 L 120 180 L 155 200 L 210 140 L 250 160 L 300 100 L 335 120 L 430 40"
        fill="freeze"
        rotate="0"
      />
    </g>

    <text x="30" y="264" class="hi-label hi-label-left">Base camp</text>
    <text x="430" y="264" class="hi-label hi-label-right" text-anchor="end">
      Making top
    </text>
  </svg>
</div>

<style>
  .hero-illus {
    width: 100%;
    max-width: 560px;
    margin-inline: auto;
    color: var(--color-ink);
  }
  .hero-illus svg {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  .hi-baseline,
  .hi-tick {
    stroke: color-mix(in srgb, currentColor 22%, transparent);
    fill: none;
    opacity: 0;
    animation: hi-fade 0.5s ease-out 0.1s forwards;
  }
  .hi-tick {
    animation-delay: 0.25s;
  }

  .hi-line {
    stroke: currentColor;
    fill: none;
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    animation: hi-draw 2s cubic-bezier(0.22, 1, 0.36, 1) 0.3s forwards;
  }

  .hi-wp {
    transform: scale(0.3);
    transform-origin: 0 0;
    transform-box: fill-box;
    opacity: 0;
  }
  .hi-wp-1 circle {
    fill: #ff4e88;
  }
  .hi-wp-2 circle,
  .hi-wp-3 circle {
    fill: #1ccb89;
  }
  .hi-wp-4 circle {
    fill: #ffcf40;
  }
  .hi-wp-1 {
    animation: hi-pop 0.5s cubic-bezier(0.22, 1, 0.36, 1) 1.55s forwards;
  }
  .hi-wp-2 {
    animation: hi-pop 0.5s cubic-bezier(0.22, 1, 0.36, 1) 1.95s forwards;
  }
  .hi-wp-3 {
    animation: hi-pop 0.5s cubic-bezier(0.22, 1, 0.36, 1) 2.35s forwards;
  }
  .hi-wp-4 {
    animation: hi-pop 0.5s cubic-bezier(0.22, 1, 0.36, 1) 3s forwards;
  }

  .hi-climber-dot {
    fill: currentColor;
  }
  .hi-climber {
    opacity: 0;
    animation: hi-fade 0.3s ease-out 1.55s forwards;
  }

  .hi-flag-pole {
    stroke: currentColor;
    opacity: 0;
    transform: translateY(4px);
    transform-origin: 0 0;
    transform-box: fill-box;
    animation: hi-rise 0.4s cubic-bezier(0.22, 1, 0.36, 1) 3.2s forwards;
  }
  .hi-flag-cloth {
    fill: var(--color-accent-mint);
    opacity: 0;
    transform: scale(0.3);
    transform-origin: 0 0;
    transform-box: fill-box;
    animation:
      hi-pop 0.4s cubic-bezier(0.22, 1, 0.36, 1) 3.35s forwards,
      hi-flag-wave 2.8s ease-in-out 4s infinite;
  }

  .hi-pulse {
    fill: color-mix(in srgb, var(--color-accent-mint) 32%, transparent);
    opacity: 0;
    transform-origin: 0 0;
    transform-box: fill-box;
    transform: scale(0.4);
    animation: hi-pulse-ring 2.6s ease-out 3.6s infinite;
  }

  .hi-label {
    font-family: inherit;
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    fill: color-mix(in srgb, currentColor 55%, transparent);
    opacity: 0;
    animation: hi-fade 0.6s ease-out forwards;
  }
  .hi-label-left {
    animation-delay: 0.5s;
  }
  .hi-label-right {
    animation-delay: 3.2s;
  }

  @keyframes hi-draw {
    to {
      stroke-dashoffset: 0;
    }
  }
  @keyframes hi-fade {
    to {
      opacity: 1;
    }
  }
  @keyframes hi-pop {
    0% {
      opacity: 0;
      transform: scale(0.3);
    }
    60% {
      opacity: 1;
      transform: scale(1.18);
    }
    100% {
      opacity: 1;
      transform: scale(1);
    }
  }
  @keyframes hi-rise {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes hi-pulse-ring {
    0% {
      opacity: 0.5;
      transform: scale(0.5);
    }
    100% {
      opacity: 0;
      transform: scale(2);
    }
  }
  @keyframes hi-flag-wave {
    0%,
    100% {
      transform: scale(1) skewX(0deg);
    }
    50% {
      transform: scale(1.03) skewX(-4deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hi-baseline,
    .hi-tick,
    .hi-label,
    .hi-climber,
    .hi-flag-pole,
    .hi-flag-cloth {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .hi-line {
      stroke-dashoffset: 0;
      animation: none;
    }
    .hi-wp {
      opacity: 1;
      transform: scale(1);
      animation: none;
    }
    .hi-pulse {
      opacity: 0;
      animation: none;
    }
    .hi-climber-dot {
      display: none;
    }
  }
</style>
