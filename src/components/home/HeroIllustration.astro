---
// Complexity → Clarity hero illustration.
// A tangled scribble on the left (ambiguity, raw data, user pain) resolves
// into a clean rising line on the right (clarity, growth, shipped outcome).
// Drawn as a single stroke so the animation tells the whole story in one gesture.
---

<div class="hero-illus" aria-hidden="true">
  <svg
    viewBox="0 0 480 280"
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    preserveAspectRatio="xMidYMid meet"
  >
    <line
      x1="20"
      y1="250"
      x2="460"
      y2="250"
      class="hi-baseline"
      stroke-width="1"
      stroke-dasharray="3 4"
      stroke-linecap="round"
    />

    <path
      d="M 26 238
         C 70 282 102 182 76 150
         C 40 112 84 74 126 108
         C 162 136 106 176 144 204
         C 176 228 118 240 186 188
         L 222 186
         Q 262 170 302 136
         L 360 94
         L 414 52
         L 452 26"
      class="hi-line"
      pathLength="100"
      stroke-width="2.6"
      stroke-linecap="round"
      stroke-linejoin="round"
    />

    <circle cx="200" cy="187" r="5.2" class="hi-turn" />

    <circle cx="452" cy="26" r="18" class="hi-pulse" />
    <circle cx="452" cy="26" r="6.2" class="hi-end" />

    <text x="30" y="260" class="hi-label hi-label-left">Complexity</text>
    <text x="452" y="14" class="hi-label hi-label-right" text-anchor="end">
      Clarity
    </text>
  </svg>
</div>

<style>
  .hero-illus {
    width: 100%;
    max-width: 560px;
    margin-inline: auto;
  }
  .hero-illus svg {
    width: 100%;
    height: auto;
    display: block;
  }
  .hi-baseline {
    stroke: color-mix(in srgb, currentColor 22%, transparent);
  }
  .hi-line {
    stroke: currentColor;
    fill: none;
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    animation: hi-draw 3s cubic-bezier(0.22, 1, 0.36, 1) 0.15s forwards;
  }
  .hi-turn {
    fill: var(--color-accent-mint);
    opacity: 0;
    transform-origin: 200px 187px;
    transform: scale(0.4);
    animation: hi-pop 0.5s cubic-bezier(0.22, 1, 0.36, 1) 1.55s forwards;
  }
  .hi-end {
    fill: var(--color-accent-mint);
    opacity: 0;
    transform-origin: 452px 26px;
    transform: scale(0.4);
    animation:
      hi-pop 0.5s cubic-bezier(0.22, 1, 0.36, 1) 3s forwards,
      hi-end-bob 2.8s ease-in-out 3.7s infinite;
  }
  .hi-pulse {
    fill: color-mix(in srgb, var(--color-accent-mint) 35%, transparent);
    opacity: 0;
    transform-origin: 452px 26px;
    transform: scale(0.4);
    animation: hi-pulse-ring 2.4s ease-out 3.3s infinite;
  }
  .hi-label {
    font-family: inherit;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    fill: color-mix(in srgb, currentColor 55%, transparent);
    opacity: 0;
    animation: hi-fade 0.6s ease-out forwards;
  }
  .hi-label-left {
    animation-delay: 0.4s;
  }
  .hi-label-right {
    animation-delay: 3.15s;
  }

  @keyframes hi-draw {
    to {
      stroke-dashoffset: 0;
    }
  }
  @keyframes hi-pop {
    0% {
      opacity: 0;
      transform: scale(0.4);
    }
    60% {
      opacity: 1;
      transform: scale(1.15);
    }
    100% {
      opacity: 1;
      transform: scale(1);
    }
  }
  @keyframes hi-pulse-ring {
    0% {
      opacity: 0.55;
      transform: scale(0.5);
    }
    100% {
      opacity: 0;
      transform: scale(2.2);
    }
  }
  @keyframes hi-end-bob {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.18);
    }
  }
  @keyframes hi-fade {
    to {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hi-line {
      stroke-dashoffset: 0;
      animation: none;
    }
    .hi-turn,
    .hi-end,
    .hi-pulse,
    .hi-label {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .hi-pulse {
      opacity: 0;
    }
  }
</style>
