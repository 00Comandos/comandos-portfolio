---
import { Image } from "astro:assets";
import ArrowIcon from "~/components/ui/ArrowIcon.astro";
import { brandImages, requireImage } from "~/lib/image-map";

const mountain = requireImage(brandImages, "mountain-white.jpg");
---

<section aria-labelledby="nfg-heading" class="pb-12 md:pb-16">
  <div class="container-page">
    <div class="rounded-xl bg-[color:var(--color-paper-warm)] p-8 md:p-14 grid md:grid-cols-2 gap-10 items-center">
      <div>
        <h2 id="nfg-heading" class="display-serif text-[2.25rem] md:text-[3rem]">
          Our secret,<br />
          <em>to create amazing products.</em>
        </h2>
        <p class="mt-5 max-w-md text-[0.95rem] leading-[1.55] text-[color:var(--color-ink-soft)]">
          North Face Growth: our methodology for creating and scaling products
          in turbo mode.
        </p>
        <a href="/north-face-growth" class="btn-outline mt-7">
          Discover North Face Growth
          <ArrowIcon />
        </a>
      </div>

      <div class="flex items-center justify-center">
        <Image
          src={mountain}
          alt="North Face Growth — mountain climb illustration"
          widths={[320, 480, 640]}
          sizes="(min-width: 768px) 420px, 100vw"
          loading="lazy"
          decoding="async"
          class="w-full max-w-sm h-auto rounded-md mix-blend-multiply"
        />
      </div>
    </div>
  </div>
</section>
