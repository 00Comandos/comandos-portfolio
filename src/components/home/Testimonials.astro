---
import { testimonials } from "~/data/testimonials";
---

<section
  aria-labelledby="testimonials-heading"
  class="py-24 md:py-32 bg-[color:var(--color-paper)]"
>
  <div class="container-page">
    <h2 id="testimonials-heading" class="sr-only">
      What clients say about Comandos
    </h2>

    <div class="testimonial-stage" data-testimonials>
      {
        testimonials.map((t, i) => (
          <figure
            class="testimonial-slide"
            data-slide-index={i}
            data-active={i === 0 ? "true" : "false"}
            aria-hidden={i === 0 ? "false" : "true"}
          >
            <blockquote class="mx-auto max-w-3xl text-center text-[1.25rem] md:text-[1.625rem] leading-[1.45] tracking-[-0.01em] text-[color:var(--color-ink-soft)]">
              &ldquo;{t.quote}&rdquo;
            </blockquote>

            <figcaption class="mt-8 md:mt-10 text-center text-sm">
              <span class="font-semibold text-[color:var(--color-ink)]">
                {t.name},
              </span>
              <span class="text-[color:var(--color-muted)]"> {t.role}</span>
            </figcaption>
          </figure>
        ))
      }
    </div>

    {
      testimonials.length > 1 && (
        <div class="mt-14 md:mt-20 border-t border-[color:var(--color-border)]">
          <div
            class="testimonial-tabs"
            data-tablist
            role="tablist"
            aria-label="Choose a testimonial"
          >
            {testimonials.map((t, i) => (
              <button
                type="button"
                class="testimonial-tab"
                data-tab-index={i}
                aria-selected={i === 0 ? "true" : "false"}
                role="tab"
              >
                {t.tabLabel}
              </button>
            ))}
          </div>
        </div>
      )
    }
  </div>
</section>

<style>
  .testimonial-stage {
    position: relative;
    display: grid;
  }
  .testimonial-stage > .testimonial-slide {
    grid-column: 1;
    grid-row: 1;
  }

  .testimonial-slide {
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 0.5s ease-out,
      transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
    margin: 0;
  }
  .testimonial-slide[data-active="true"] {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .testimonial-tabs {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 2rem;
    overflow-x: auto;
    padding: 1.75rem 1.5rem 0.5rem;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    mask-image: linear-gradient(
      90deg,
      transparent 0,
      black 6%,
      black 94%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent 0,
      black 6%,
      black 94%,
      transparent 100%
    );
  }
  .testimonial-tabs::-webkit-scrollbar {
    display: none;
  }

  @media (min-width: 768px) {
    .testimonial-tabs {
      justify-content: center;
      gap: 3rem;
      mask-image: none;
      -webkit-mask-image: none;
    }
  }

  .testimonial-tab {
    position: relative;
    background: transparent;
    border: 0;
    padding: 0.5rem 0;
    font: inherit;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: color-mix(in srgb, var(--color-ink) 38%, transparent);
    cursor: pointer;
    transition: color 0.2s ease;
    white-space: nowrap;
    flex-shrink: 0;
    scroll-snap-align: center;
  }
  .testimonial-tab:hover {
    color: color-mix(in srgb, var(--color-ink) 70%, transparent);
  }
  .testimonial-tab[aria-selected="true"] {
    color: var(--color-ink);
  }
  .testimonial-tab::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -9px;
    height: 2px;
    background: var(--color-ink);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .testimonial-tab[aria-selected="true"]::after {
    transform: scaleX(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .testimonial-slide,
    .testimonial-tab::after {
      transition: none;
      transform: none;
    }
  }
</style>

<script>
  const ROTATE_MS = 8000;

  document
    .querySelectorAll<HTMLElement>("[data-testimonials]")
    .forEach((stage) => {
      const slides = Array.from(
        stage.querySelectorAll<HTMLElement>(".testimonial-slide"),
      );
      if (slides.length <= 1) return;

      const section = stage.closest("section");
      const scope = section ?? document;
      const tabList = scope.querySelector<HTMLElement>("[data-tablist]");
      const tabs = Array.from(
        scope.querySelectorAll<HTMLButtonElement>("[data-tab-index]"),
      );

      let current = 0;
      let timer: number | null = null;
      let paused = false;

      const show = (index: number) => {
        const next = (index + slides.length) % slides.length;
        slides.forEach((s, i) => {
          const isActive = i === next;
          s.setAttribute("data-active", isActive ? "true" : "false");
          s.setAttribute("aria-hidden", isActive ? "false" : "true");
        });
        tabs.forEach((d, i) => {
          d.setAttribute("aria-selected", i === next ? "true" : "false");
        });
        const activeTab = tabs[next];
        if (activeTab && tabList) {
          const overflows = tabList.scrollWidth > tabList.clientWidth + 2;
          if (overflows) {
            const target =
              activeTab.offsetLeft -
              tabList.clientWidth / 2 +
              activeTab.clientWidth / 2;
            tabList.scrollTo({
              left: Math.max(0, target),
              behavior: "smooth",
            });
          }
        }
        current = next;
      };

      const start = () => {
        if (timer !== null) return;
        timer = window.setInterval(() => {
          if (!paused) show(current + 1);
        }, ROTATE_MS);
      };
      const stop = () => {
        if (timer !== null) {
          window.clearInterval(timer);
          timer = null;
        }
      };

      tabs.forEach((tab, i) => {
        tab.addEventListener("click", () => {
          show(i);
          stop();
          start();
        });
      });

      stage.addEventListener("pointerenter", () => {
        paused = true;
      });
      stage.addEventListener("pointerleave", () => {
        paused = false;
      });

      const prefersReduced = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;
      if (!prefersReduced) start();
    });
</script>
