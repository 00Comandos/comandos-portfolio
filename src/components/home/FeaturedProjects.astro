---
import { Image } from "astro:assets";
import ArrowIcon from "~/components/ui/ArrowIcon.astro";
import { projects } from "~/data/projects";

const curatedSlugs = [
  "stori-inversion-plus",
  "karta-app",
  "legalario-e-signature",
  "truora-report",
  "rebajatuscuentas",
  "mipos-restaurant-pos",
  "spotfinder",
] as const;

const curated = curatedSlugs
  .map((slug) => projects.find((p) => p.slug === slug))
  .filter((p): p is (typeof projects)[number] => Boolean(p));

const [featured, ...rest] = curated;
---

<section
  id="featured-projects"
  aria-labelledby="featured-projects-heading"
  class="py-24 md:py-32 bg-[color:var(--color-paper-soft)]"
>
  <div class="container-page">
    <div class="fw-reveal max-w-2xl">
      <p class="text-xs font-semibold tracking-[0.18em] uppercase text-[color:var(--color-muted)]">
        High-Impact Products
      </p>
      <h2
        id="featured-projects-heading"
        class="mt-3 text-3xl md:text-[2.5rem] font-extrabold leading-[1.1] tracking-tight"
      >
        Products that millions of people actually use
      </h2>
      <p class="mt-4 text-[color:var(--color-muted)] leading-[1.6]">
        Selected product design work across FinTech, SaaS, IoT and FoodTech in
        Mexico and LATAM — from Stori and Karta to Yaydoo, mipOS and Spotfinder.
      </p>
    </div>

    {
      featured && (
        <a
          href={`/projects/${featured.slug}`}
          class="fw-card fw-reveal group mt-14 md:mt-20 block"
          aria-label={`${featured.brand} — ${featured.title}`}
        >
          <div class="fw-card-media overflow-hidden bg-[color:var(--color-paper)]">
            <Image
              src={featured.image}
              alt={`${featured.brand} — ${featured.title}. ${featured.description}`}
              widths={[720, 1080, 1440, 1920]}
              sizes="(min-width: 1024px) 1100px, 100vw"
              loading="eager"
              decoding="async"
              class="fw-card-img h-full w-full object-cover aspect-[4/3] md:aspect-[2.4/1]"
            />
          </div>
          <div class="mt-7 md:mt-8 max-w-3xl">
            <p class="fw-kicker text-[0.72rem] tracking-[0.18em] font-mono uppercase text-[color:var(--color-muted)]">
              {featured.brand}
            </p>
            <h3 class="fw-title mt-3 text-[1.5rem] md:text-[1.875rem] leading-[1.2] font-semibold text-[color:var(--color-ink)]">
              {featured.title}
            </h3>
            <p class="mt-3 text-[0.975rem] leading-[1.55] text-[color:var(--color-muted)] max-w-xl">
              {featured.description}
            </p>
            <p class="mt-4 text-[0.825rem] tracking-tight">
              <span class="font-semibold text-[color:var(--color-ink)]">
                {featured.impact}
              </span>
              <span class="text-[color:var(--color-muted)]"> · {featured.timeline}</span>
            </p>
          </div>
        </a>
      )
    }

    <ul
      class="mt-24 md:mt-28 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-14 md:gap-16 lg:gap-20"
      role="list"
    >
      {
        rest.map((p) => (
          <li class="fw-reveal">
            <a
              href={`/projects/${p.slug}`}
              class="fw-card group block h-full"
              aria-label={`${p.brand} — ${p.title}`}
            >
              <div class="fw-card-media overflow-hidden bg-[color:var(--color-paper)]">
                <Image
                  src={p.image}
                  alt={`${p.brand} — ${p.title}. ${p.description}`}
                  widths={[360, 540, 720, 960]}
                  sizes="(min-width: 1024px) 360px, (min-width: 640px) 50vw, 100vw"
                  loading="lazy"
                  decoding="async"
                  class="fw-card-img h-full w-full object-cover aspect-[4/3]"
                />
              </div>
              <p class="fw-kicker mt-6 text-[0.7rem] tracking-[0.18em] font-mono uppercase text-[color:var(--color-muted)]">
                {p.brand}
              </p>
              <h3 class="fw-title mt-3 text-[1.25rem] md:text-[1.375rem] leading-[1.25] font-semibold text-[color:var(--color-ink)]">
                {p.title}
              </h3>
              <p class="mt-2 text-[0.95rem] leading-[1.55] text-[color:var(--color-muted)]">
                {p.description}
              </p>
              <p class="mt-3 text-[0.8rem] tracking-tight">
                <span class="font-semibold text-[color:var(--color-ink)]">
                  {p.impact}
                </span>
                <span class="text-[color:var(--color-muted)]"> · {p.timeline}</span>
              </p>
            </a>
          </li>
        ))
      }
    </ul>

    <div class="fw-reveal mt-24 md:mt-28 flex justify-center">
      <a href="/projects" class="btn-outline">
        View all projects
        <ArrowIcon />
      </a>
    </div>
  </div>
</section>

<style>
  .fw-card {
    color: inherit;
  }
  .fw-card-img {
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .fw-card:hover .fw-card-img,
  .fw-card:focus-visible .fw-card-img {
    transform: scale(1.03);
  }
  .fw-title {
    transition: opacity 0.2s ease;
  }
  .fw-card:hover .fw-title {
    opacity: 0.7;
  }
  .fw-card:focus-visible {
    outline: 2px solid var(--color-ink);
    outline-offset: 6px;
    border-radius: 4px;
  }

  .fw-reveal {
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: opacity, transform;
  }
  .fw-reveal[data-in-view="true"] {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .fw-card-img,
    .fw-title {
      transition: none;
    }
    .fw-reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const targets = document.querySelectorAll<HTMLElement>(".fw-reveal");

  if (reduce) {
    targets.forEach((el) => el.setAttribute("data-in-view", "true"));
  } else if ("IntersectionObserver" in window) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.setAttribute("data-in-view", "true");
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: "0px 0px -40px 0px" },
    );
    targets.forEach((el) => io.observe(el));
  } else {
    targets.forEach((el) => el.setAttribute("data-in-view", "true"));
  }
</script>
