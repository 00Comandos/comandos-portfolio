---
import { Image } from "astro:assets";
import ArrowIcon from "~/components/ui/ArrowIcon.astro";
import { projects } from "~/data/projects";

const featuredSlugs = [
  "stori-inversion-plus",
  "karta-app",
  "legalario-e-signature",
  "truora-report",
  "yaydoo-porcobrar",
  "rebajatuscuentas",
  "mipos-restaurant-pos",
  "spotfinder",
] as const;

const featured = featuredSlugs
  .map((slug) => projects.find((p) => p.slug === slug))
  .filter((p): p is (typeof projects)[number] => Boolean(p));
---

<section
  id="featured-projects"
  aria-labelledby="featured-projects-heading"
  class="py-20 md:py-28 bg-[color:var(--color-paper)]"
>
  <div class="container-page">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
      <div>
        <p class="text-xs font-semibold tracking-[0.18em] uppercase text-[color:var(--color-muted)]">
          Featured Case Studies
        </p>
        <h2
          id="featured-projects-heading"
          class="mt-3 text-3xl md:text-[2.5rem] font-extrabold leading-[1.1] tracking-tight max-w-2xl"
        >
          Products that millions of people actually use
        </h2>
        <p class="mt-4 max-w-xl text-[color:var(--color-muted)] leading-[1.6]">
          Selected product design work across FinTech, SaaS, IoT and FoodTech in
          Mexico and LATAM — from Stori and Karta to Yaydoo, mipOS and Spotfinder.
        </p>
      </div>
      <a href="/projects" class="btn-outline self-start md:self-end whitespace-nowrap">
        View all projects
        <ArrowIcon />
      </a>
    </div>

    <ul
      class="mt-12 md:mt-14 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-7"
      role="list"
    >
      {
        featured.map((p) => (
          <li>
            <a
              href={`/projects/${p.slug}`}
              class="featured-card group block h-full"
              aria-label={`${p.brand} — ${p.title}`}
            >
              <div class="featured-thumb relative overflow-hidden rounded-lg bg-[color:var(--color-paper-soft)]">
                <Image
                  src={p.image}
                  alt={`${p.brand} — ${p.title}. ${p.description}`}
                  widths={[320, 480, 640, 960]}
                  sizes="(min-width: 1024px) 280px, (min-width: 640px) 45vw, 100vw"
                  loading="lazy"
                  decoding="async"
                  class="featured-thumb-img h-full w-full object-cover aspect-[4/5]"
                />
                <span class="absolute top-3 left-3 bg-[color:var(--color-paper)] text-[0.78rem] font-semibold px-3 py-1 rounded-full shadow-[0_1px_3px_rgba(0,0,0,0.12)]">
                  {p.brand}
                </span>
                <span class="absolute top-3 right-3 bg-[color:var(--color-accent-mint)] text-[color:var(--color-ink)] text-[0.72rem] font-bold px-2.5 py-1 rounded-full tracking-tight">
                  {p.impact}
                </span>
              </div>

              <h3 class="mt-4 text-[1.0625rem] font-bold leading-[1.3] tracking-tight text-[color:var(--color-ink)] group-hover:opacity-70 transition-opacity">
                {p.title}
              </h3>
              <p class="mt-1.5 text-[0.85rem] text-[color:var(--color-muted)]">
                {p.timeline}
              </p>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .featured-thumb-img {
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .featured-card:hover .featured-thumb-img,
  .featured-card:focus-visible .featured-thumb-img {
    transform: scale(1.04);
  }
  .featured-card:focus-visible {
    outline: 2px solid var(--color-ink);
    outline-offset: 4px;
    border-radius: 8px;
  }
</style>
