---
import { Image } from "astro:assets";
import ArrowIcon from "~/components/ui/ArrowIcon.astro";
import { homeBeforeAfter } from "~/data/home-before-after";
---

<section
  id="before-after"
  aria-labelledby="before-after-heading"
  class="py-24 md:py-32 bg-[color:var(--color-paper-soft)]"
>
  <div class="container-page">
    <div class="ba-reveal mx-auto max-w-3xl text-center">
      <p class="text-xs font-semibold tracking-[0.18em] uppercase text-[color:var(--color-muted)]">
        Before / After Comandos
      </p>
      <h2
        id="before-after-heading"
        class="mt-3 text-[2rem] md:text-[2.75rem] font-extrabold leading-[1.08] tracking-tight"
      >
        Product problems, measurably solved.
      </h2>
      <p class="mt-4 text-[color:var(--color-muted)] leading-[1.6]">
        Real transformations from FinTech, IoT and FoodTech case studies — the
        state we inherited, the state we shipped, and the metric the team moved.
      </p>
    </div>

    <ul
      class="mt-16 md:mt-20 grid grid-cols-1 lg:grid-cols-2 gap-10 md:gap-12"
      role="list"
    >
      {
        homeBeforeAfter.map((c) => (
          <li class="ba-reveal">
            <a
              href={`/projects/${c.slug}`}
              class="ba-card group block h-full"
              aria-label={`${c.brand} — ${c.tagline}`}
            >
              <div class="grid grid-cols-2 gap-2 md:gap-3">
                <figure class="ba-half ba-before">
                  <div class="ba-media">
                    <Image
                      src={c.before}
                      alt={c.beforeAlt}
                      widths={[320, 480, 640]}
                      sizes="(min-width: 1024px) 280px, 50vw"
                      loading="lazy"
                      decoding="async"
                      class="ba-img"
                    />
                    <span class="ba-tag ba-tag-before">Before</span>
                  </div>
                </figure>
                <figure class="ba-half ba-after">
                  <div class="ba-media">
                    <Image
                      src={c.after}
                      alt={c.afterAlt}
                      widths={[320, 480, 640]}
                      sizes="(min-width: 1024px) 280px, 50vw"
                      loading="lazy"
                      decoding="async"
                      class="ba-img"
                    />
                    <span class="ba-tag ba-tag-after">After</span>
                  </div>
                </figure>
              </div>

              <div class="mt-5">
                <p class="text-[0.7rem] tracking-[0.18em] font-mono uppercase text-[color:var(--color-muted)]">
                  {c.brand}
                </p>
                <h3 class="ba-title mt-2 text-[1.125rem] md:text-[1.25rem] leading-[1.3] font-semibold text-[color:var(--color-ink)]">
                  {c.tagline}
                </h3>
                <p class="mt-2 text-[0.9rem] font-semibold text-[color:var(--color-ink)]">
                  {c.impact}
                </p>
              </div>
            </a>
          </li>
        ))
      }
    </ul>

    <div class="ba-reveal mt-20 md:mt-24 flex justify-center">
      <a href="/projects" class="btn-outline">
        See all case studies
        <ArrowIcon />
      </a>
    </div>
  </div>
</section>

<style>
  .ba-card {
    color: inherit;
  }
  .ba-media {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: var(--color-paper);
    border-radius: 2px;
  }
  .ba-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .ba-card:hover .ba-img,
  .ba-card:focus-visible .ba-img {
    transform: scale(1.04);
  }

  .ba-tag {
    position: absolute;
    top: 10px;
    left: 10px;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 0.25rem 0.55rem;
    border-radius: 999px;
    line-height: 1;
  }
  .ba-tag-before {
    background: color-mix(in srgb, var(--color-ink) 92%, transparent);
    color: var(--color-paper);
  }
  .ba-tag-after {
    background: var(--color-accent-mint);
    color: var(--color-ink);
  }

  .ba-title {
    transition: opacity 0.2s ease;
  }
  .ba-card:hover .ba-title {
    opacity: 0.7;
  }
  .ba-card:focus-visible {
    outline: 2px solid var(--color-ink);
    outline-offset: 6px;
    border-radius: 4px;
  }

  .ba-reveal {
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .ba-reveal[data-in-view="true"] {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .ba-img,
    .ba-title {
      transition: none;
    }
    .ba-reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const targets = document.querySelectorAll<HTMLElement>(
    "#before-after .ba-reveal",
  );

  if (reduce) {
    targets.forEach((el) => el.setAttribute("data-in-view", "true"));
  } else if ("IntersectionObserver" in window) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.setAttribute("data-in-view", "true");
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: "0px 0px -40px 0px" },
    );
    targets.forEach((el) => io.observe(el));
  } else {
    targets.forEach((el) => el.setAttribute("data-in-view", "true"));
  }
</script>
