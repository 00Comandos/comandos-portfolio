---
import Logo from "~/components/ui/Logo.astro";
import ArrowIcon from "~/components/ui/ArrowIcon.astro";
import { site } from "~/lib/site";

const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-[color:var(--color-border)] bg-[color:var(--color-paper-soft)]">
  <div class="container-page py-14 grid gap-10 md:grid-cols-4">
    <div class="md:col-span-2">
      <Logo />
      <p class="mt-4 max-w-sm text-sm leading-relaxed text-[color:var(--color-muted)]">
        {site.description}
      </p>
      <a href="/contact" class="btn-primary mt-6">
        Start a project
        <ArrowIcon />
      </a>
    </div>

    <div>
      <h4 class="text-xs font-semibold tracking-[0.12em] uppercase text-[color:var(--color-muted)]">
        Navigation
      </h4>
      <ul class="mt-4 space-y-2 text-sm">
        {
          site.nav.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-[color:var(--color-ink)] hover:text-[color:var(--color-accent)] transition-colors"
              >
                {item.label}
              </a>
            </li>
          ))
        }
        <li>
          <a
            href="/north-face-growth"
            class="text-[color:var(--color-ink)] hover:text-[color:var(--color-accent)] transition-colors"
          >
            North Face Growth
          </a>
        </li>
      </ul>
    </div>

    <div>
      <h4 class="text-xs font-semibold tracking-[0.12em] uppercase text-[color:var(--color-muted)]">
        Contact
      </h4>
      <ul class="mt-4 space-y-2 text-sm">
        <li>
          <a
            href={site.social.email}
            class="text-[color:var(--color-ink)] hover:text-[color:var(--color-accent)] transition-colors"
          >
            c@comandos.me
          </a>
        </li>
        <li>
          <a
            href={site.social.linkedin}
            rel="noopener noreferrer"
            target="_blank"
            class="text-[color:var(--color-ink)] hover:text-[color:var(--color-accent)] transition-colors"
          >
            LinkedIn
          </a>
        </li>
        <li>
          <a
            href={site.social.twitter}
            rel="noopener noreferrer"
            target="_blank"
            class="text-[color:var(--color-ink)] hover:text-[color:var(--color-accent)] transition-colors"
          >
            Twitter
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-[color:var(--color-border)]">
    <div class="container-page py-6 flex flex-col md:flex-row items-center justify-between gap-3 text-xs text-[color:var(--color-muted)]">
      <p>© {year} Comandos. All rights reserved.</p>
      <p>Product design from Mexico City 🇲🇽 to the world.</p>
    </div>
  </div>
</footer>
