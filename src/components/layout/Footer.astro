88 160.325 21.3266 160.325 22.9949Z";
---

<footer class="footer">
  <div class="container-page footer-inner">
    <div class="grid gap-12 md:gap-10 md:grid-cols-4">
      <div class="md:col-span-2">
        <img
          src="/images/Logo-Comandos-white.svg"
          alt="Comandos"
          height={34}
          width={Math.round((161 / 35) * 34)}
          style="height: 34px; width: auto;"
          class="footer-logo"
          loading="lazy"
          decoding="async"
        />
        <p class="mt-5 max-w-sm text-sm leading-relaxed footer-muted">
          {site.description}
        </p>
        <a href="/contact" class="footer-cta mt-6">
          <span>Start a project</span>
          <span class="footer-cta-arrow"><ArrowIcon /></span>
        </a>
      </div>

      <div>
        <h4 class="footer-col-title">Navigation</h4>
        <ul class="mt-5 space-y-3 text-sm">
          {
            site.nav.map((item) => (
              <li>
                <a href={item.href} class="footer-link">
                  {item.label}
                </a>
              </li>
            ))
          }
          <li>
            <a href="/north-face-growth" class="footer-link">North Face Growth</a>
          </li>
        </ul>
      </div>

      <div>
        <h4 class="footer-col-title">Social</h4>
        <ul class="mt-5 space-y-3 text-sm">
          <li>
            <a
              href={site.social.linkedin}
              rel="noopener noreferrer"
              target="_blank"
              class="footer-link"
            >
              LinkedIn
            </a>
          </li>
          <li>
            <a
              href={site.social.twitter}
              rel="noopener noreferrer"
              target="_blank"
              class="footer-link"
            >
              Twitter
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="footer-halftone" aria-hidden="true">
    <div class="halftone-bloom"></div>
    <div class="halftone-stack">
      <svg
        class="halftone-svg halftone-ghost"
        viewBox="0 0 161 35"
        preserveAspectRatio="xMidYMid meet"
        xmlns="http://www.w3.org/2000/svg"
        role="presentation"
      >
        <path fill-rule="evenodd" clip-rule="evenodd" d={LOGO_PATH} fill="currentColor"></path>
      </svg>
      <svg
        class="halftone-svg halftone-dots"
        viewBox="0 0 161 35"
        preserveAspectRatio="xMidYMid meet"
        xmlns="http://www.w3.org/2000/svg"
        role="presentation"
      >
        <defs>
          <pattern
            id="halftone-dots-pattern"
            x="0"
            y="0"
            width="0.9"
            height="0.9"
            patternUnits="userSpaceOnUse"
          >
            <circle cx="0.45" cy="0.45" r="0.28" fill="currentColor"></circle>
          </pattern>
        </defs>
        <path fill-rule="evenodd" clip-rule="evenodd" d={LOGO_PATH} fill="url(#halftone-dots-pattern)"></path>
      </svg>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container-page text-xs footer-muted">
      <p>© {year} Comandos. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: 6rem;
    background-color: var(--color-ink);
    color: var(--color-paper);
    position: relative;
    overflow: hidden;
  }

  .footer-inner {
    padding-top: 4.5rem;
    padding-bottom: 2rem;
    position: relative;
    z-index: 2;
  }

  .footer-logo {
    display: block;
  }

  .footer-col-title {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-paper);
  }

  .footer-muted {
    color: color-mix(in srgb, var(--color-paper) 55%, transparent);
  }

  .footer-link {
    color: color-mix(in srgb, var(--color-paper) 82%, transparent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition:
      color 0.15s ease,
      border-color 0.15s ease;
  }
  .footer-link:hover,
  .footer-link:focus-visible {
    color: var(--color-paper);
    border-bottom-color: var(--color-paper);
  }

  .footer-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.65rem 1.2rem;
    border-radius: 9999px;
    background-color: var(--color-paper);
    color: var(--color-ink);
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    transition:
      background-color 0.2s ease,
      transform 0.2s ease;
  }
  .footer-cta:hover {
    background-color: var(--color-accent-mint);
    transform: translateY(-1px);
  }
  .footer-cta-arrow :global(svg) {
    width: 14px;
    height: 14px;
  }

  /* ———— Halftone Comandos logo (Capchase-style) ————
     Two stacked SVGs of the same wordmark:
       1. A faint solid "ghost" silhouette on the bottom — shows through
          at the edges where the dots fade out.
       2. A dotted pattern layer on top, masked with a radial gradient
          whose focus sits below center (50% 80%) — this mimics the
          "backlit-from-below" look of the Capchase reference where
          letters are brightest just above the baseline.
     A blurred paper-coloured bloom sits behind the stack, concentrated
     near the baseline, to echo the soft halo under the reference. */
  .footer-halftone {
    position: relative;
    z-index: 1;
    width: 100%;
    padding: 3rem 0 3.5rem;
    pointer-events: none;
    user-select: none;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .halftone-bloom {
    position: absolute;
    left: 50%;
    bottom: 20%;
    transform: translateX(-50%);
    width: min(55%, 720px);
    aspect-ratio: 5 / 1;
    background: radial-gradient(
      ellipse at center,
      color-mix(in srgb, var(--color-paper) 14%, transparent) 0%,
      color-mix(in srgb, var(--color-paper) 5%, transparent) 40%,
      transparent 72%
    );
    filter: blur(30px);
    pointer-events: none;
    z-index: 0;
  }
  .halftone-stack {
    position: relative;
    width: min(78%, 1000px);
    z-index: 1;
  }
  .halftone-svg {
    display: block;
    width: 100%;
    height: auto;
    color: var(--color-paper);
  }
  .halftone-ghost {
    position: absolute;
    inset: 0;
    opacity: 0.05;
    z-index: 1;
  }
  .halftone-dots {
    position: relative;
    z-index: 2;
    opacity: 0.95;
    -webkit-mask-image: radial-gradient(
      ellipse 55% 95% at 50% 82%,
      rgba(0, 0, 0, 1) 0%,
      rgba(0, 0, 0, 0.88) 22%,
      rgba(0, 0, 0, 0.45) 55%,
      rgba(0, 0, 0, 0.12) 80%,
      rgba(0, 0, 0, 0) 100%
    );
    mask-image: radial-gradient(
      ellipse 55% 95% at 50% 82%,
      rgba(0, 0, 0, 1) 0%,
      rgba(0, 0, 0, 0.88) 22%,
      rgba(0, 0, 0, 0.45) 55%,
      rgba(0, 0, 0, 0.12) 80%,
      rgba(0, 0, 0, 0) 100%
    );
  }

  .footer-bottom {
    border-top: 1px solid color-mix(in srgb, var(--color-paper) 12%, transparent);
    padding: 1.1rem 0 1.4rem;
    position: relative;
    z-index: 2;
  }

  @media (max-width: 767px) {
    .footer-halftone {
      padding: 2rem 0 2.5rem;
    }
    .halftone-stack {
      width: 92%;
    }
  }
</style>
