---
import ArrowIcon from "~/components/ui/ArrowIcon.astro";
import { site } from "~/lib/site";

const year = new Date().getFullYear();

// Shared path for the Comandos wordmark — reused in the intro logo
// and again as the huge halftone treatment at the bottom.
