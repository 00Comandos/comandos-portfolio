---
type Props = {
  height?: number;
  class?: string;
};

const { height = 40, class: className = "" } = Astro.props;
---

<img
  src="/images/Logo-Comandos.svg"
  alt="Comandos"
  height={height}
  width={Math.round((161 / 35) * height)}
  style={`height: ${height}px; width: auto;`}
  class={`block ${className}`}
/>
