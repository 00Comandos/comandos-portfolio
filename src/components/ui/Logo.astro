---
type Props = {
  size?: number;
  withWordmark?: boolean;
  class?: string;
};

const { size = 28, withWordmark = true, class: className = "" } = Astro.props;
---

<span class={`inline-flex items-center gap-2 ${className}`}>
  <svg
    width={size}
    height={size}
    viewBox="0 0 32 32"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
    role="img"
  >
    <rect x="3" y="5" width="22" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8" />
    <rect x="7" y="14" width="22" height="13" rx="1.5" stroke="currentColor" stroke-width="1.8" />
  </svg>
  {withWordmark && <span class="font-semibold tracking-tight text-[1.05rem]">Comandos</span>}
</span>
