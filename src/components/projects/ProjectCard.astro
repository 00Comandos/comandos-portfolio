---
import ArrowIcon from "~/components/ui/ArrowIcon.astro";
import Placeholder from "~/components/ui/Placeholder.astro";
import type { Project } from "~/data/projects";

type Props = { project: Project };
const { project } = Astro.props;
---

<article class="grid md:grid-cols-[minmax(0,240px)_1fr] gap-5 md:gap-8 items-start py-6 border-b border-[color:var(--color-border)] last:border-b-0">
  <a
    href={`/projects/${project.slug}`}
    class="relative block overflow-hidden rounded-lg group"
    aria-label={`${project.brand} — ${project.title}`}
  >
    <Placeholder
      ratio="4 / 5"
      label={`${project.brand} image`}
      class="w-full"
    />
    <span class="absolute top-3 left-3 bg-[color:var(--color-paper)] text-[0.7rem] font-semibold px-3 py-1 rounded-full shadow-[0_1px_2px_rgba(0,0,0,0.12)]">
      {project.brand}
    </span>
  </a>

  <div class="flex flex-col">
    <h3 class="text-lg md:text-[1.35rem] font-bold leading-[1.2] tracking-tight">
      <a
        href={`/projects/${project.slug}`}
        class="hover:text-[color:var(--color-accent)] transition-colors"
      >
        {project.title}
      </a>
    </h3>

    <p class="mt-3 text-[0.95rem] leading-[1.55] text-[color:var(--color-muted)] max-w-xl">
      {project.description}
    </p>

    <dl class="mt-5 flex flex-wrap gap-x-6 gap-y-2 text-sm">
      <div class="flex items-center gap-1.5">
        <span aria-hidden="true" class="text-[color:var(--color-accent-mint)]">↗</span>
        <dt class="sr-only">Impact</dt>
        <dd class="font-medium">{project.impact}</dd>
      </div>
      <div class="flex items-center gap-1.5">
        <span aria-hidden="true" class="text-[color:var(--color-accent-sun)]">⏱</span>
        <dt class="sr-only">Timeline</dt>
        <dd class="font-medium">{project.timeline}</dd>
      </div>
    </dl>

    <a
      href={`/projects/${project.slug}`}
      class="btn-outline mt-6 self-start"
    >
      View case study
      <ArrowIcon />
    </a>
  </div>
</article>
