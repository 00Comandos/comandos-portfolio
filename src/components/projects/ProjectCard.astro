---
import { Image } from "astro:assets";
import ArrowIcon from "~/components/ui/ArrowIcon.astro";
import type { Project } from "~/data/projects";

type Props = { project: Project };
const { project } = Astro.props;
---

<article class="grid md:grid-cols-[minmax(0,240px)_1fr] gap-5 md:gap-8 items-start py-6 border-b border-[color:var(--color-border)] last:border-b-0">
  <a
    href={`/projects/${project.slug}`}
    class="project-thumb relative block overflow-hidden rounded-lg bg-[color:var(--color-paper-soft)]"
    aria-label={`${project.brand} — ${project.title}`}
  >
    <Image
      src={project.image}
      alt={`${project.brand} — ${project.title}`}
      widths={[240, 360, 480, 720]}
      sizes="(min-width: 768px) 240px, 100vw"
      loading="lazy"
      decoding="async"
      class="project-thumb-img h-full w-full object-cover aspect-[4/5]"
    />
    <span class="absolute top-4 left-4 bg-[color:var(--color-paper)] text-[0.875rem] font-semibold px-4 py-1.5 rounded-full shadow-[0_1px_3px_rgba(0,0,0,0.14)]">
      {project.brand}
    </span>
  </a>

  <div class="flex flex-col">
    <h3 class="text-xl md:text-[1.625rem] font-bold leading-[1.2] tracking-tight">
      <a href={`/projects/${project.slug}`} class="case-title">
        {project.title}
      </a>
    </h3>

    <p class="mt-3 text-[0.95rem] leading-[1.55] text-[color:var(--color-muted)] max-w-xl">
      {project.description}
    </p>

    <dl class="mt-5 flex flex-wrap gap-x-6 gap-y-2 text-sm">
      <div class="flex items-center gap-1.5">
        <img
          src="/images/arrow-growth.svg"
          alt=""
          width="18"
          height="18"
          loading="lazy"
          class="h-[18px] w-[18px] shrink-0"
        />
        <dt class="sr-only">Impact</dt>
        <dd class="font-medium">{project.impact}</dd>
      </div>
      <div class="flex items-center gap-1.5">
        <img
          src="/images/icon-watch-alt.svg"
          alt=""
          width="18"
          height="18"
          loading="lazy"
          class="h-[18px] w-[18px] shrink-0"
        />
        <dt class="sr-only">Timeline</dt>
        <dd class="font-medium">{project.timeline}</dd>
      </div>
    </dl>

    <a
      href={`/projects/${project.slug}`}
      class="btn-outline mt-6 self-start"
    >
      View case study
      <ArrowIcon />
    </a>
  </div>
</article>

<style>
  .project-thumb-img {
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .project-thumb:hover .project-thumb-img {
    transform: scale(1.04);
  }
  .case-title {
    transition: opacity 0.18s ease;
  }
  .case-title:hover {
    opacity: 0.7;
  }
</style>
