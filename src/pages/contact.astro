---
import BaseLayout from "~/layouts/BaseLayout.astro";
import ContactForm from "~/components/contact/ContactForm.astro";
import { site } from "~/lib/site";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Contact — Comandos",
  url: `${site.url}/contact`,
  description:
    "Partner with Comandos on your next FinTech or SaaS product. Tell us about your project.",
};
---

<BaseLayout
  title="Contact"
  description="Partner with Comandos on your next FinTech or SaaS product. Tell us about your project and we'll be in touch."
  jsonLd={jsonLd}
>
  <section class="container-page pt-14 md:pt-20 pb-24">
    <div class="grid gap-12 md:gap-16 md:grid-cols-2 items-start">
      <div class="md:sticky md:top-24">
        <h1 class="display-serif text-[3rem] md:text-[3.75rem]">
          Let's build something<br />
          <em>millions of people use.</em>
        </h1>
        <p class="mt-5 max-w-md text-[1.0625rem] leading-[1.55] text-[color:var(--color-muted)]">
          Tell us about your product, team, and stage. We'll reply within one
          business day.
        </p>
      </div>

      <div>
        <ContactForm />
      </div>
    </div>
  </section>
</BaseLayout>
