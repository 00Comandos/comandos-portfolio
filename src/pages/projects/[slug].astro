---
import { Image, getImage } from "astro:assets";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ArrowIcon from "~/components/ui/ArrowIcon.astro";
import CaseStudyNav from "~/components/case-study/CaseStudyNav.astro";
import CaseStudyHeader from "~/components/case-study/CaseStudyHeader.astro";
import Challenge from "~/components/case-study/Challenge.astro";
import Adventure from "~/components/case-study/Adventure.astro";
import Worth from "~/components/case-study/Worth.astro";
import Result from "~/components/case-study/Result.astro";
import RelatedCases from "~/components/case-study/RelatedCases.astro";
import { projects, getProjectBySlug, getRelatedProjects } from "~/data/projects";
import { getCaseStudy } from "~/data/case-studies";
import { extractCaseStudyImages } from "~/lib/case-study-images";
import { site } from "~/lib/site";

export const prerender = true;

export function getStaticPaths() {
  return projects.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const project = slug ? getProjectBySlug(slug) : undefined;

if (!project) {
  return Astro.redirect("/projects", 302);
}

const caseStudy = getCaseStudy(project.slug);
const related = getRelatedProjects(project.slug, 3);

// Generate a 1200-wide OG image from the case study hero when available,
// falling back to the project thumbnail. Absolute URL for social crawlers.
const ogSource =
  caseStudy?.hero.image && caseStudy.hero.image.kind === "image"
    ? caseStudy.hero.image.image
    : project.image;

const ogVariant = await getImage({
  src: ogSource,
  width: 1200,
  format: "webp",
});
const ogImageAbs = new URL(ogVariant.src, site.url).toString();

// Emit every case-study image into JSON-LD as an ImageObject so Google
// Image Search indexes each with its alt (caption) + optional caption
// (description). Deduplicated by underlying ImageMetadata.src.
const inPageImages = caseStudy ? extractCaseStudyImages(caseStudy) : [];
const seen = new Set<string>();
const dedupedImages = inPageImages.filter((ci) => {
  const key = ci.image.src;
  if (seen.has(key)) return false;
  seen.add(key);
  return true;
});
const imageObjects = await Promise.all(
  dedupedImages.map(async (ci) => {
    const v = await getImage({
      src: ci.image,
      width: 1200,
      format: "webp",
    });
    return {
      "@type": "ImageObject" as const,
      url: new URL(v.src, site.url).toString(),
      caption: ci.alt,
      description: ci.caption ?? ci.alt,
      width: v.attributes?.width ?? ci.image.width ?? 1200,
      height: v.attributes?.height ?? ci.image.height ?? 800,
    };
  }),
);

const primaryImage = {
  "@type": "ImageObject" as const,
  url: ogImageAbs,
  width: 1200,
  height: ogVariant.attributes?.height ?? 800,
};

// Build-time timestamp used as a conservative publish / modified date so
// Google has recency signal on the article even before real editorial
// metadata ships.
const buildIso = new Date().toISOString();

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: project.title,
    name: project.title,
    url: `${site.url}/projects/${project.slug}`,
    mainEntityOfPage: `${site.url}/projects/${project.slug}`,
    about: project.brand,
    description: project.description,
    keywords: `${project.brand}, ${project.title}, product design, case study, LATAM, FinTech, SaaS, UX research`,
    inLanguage: "en",
    datePublished: buildIso,
    dateModified: buildIso,
    author: {
      "@type": "Person",
      name: site.person.name,
      url: site.url,
    },
    publisher: {
      "@type": "Organization",
      name: site.name,
      url: site.url,
      logo: {
        "@type": "ImageObject",
        url: new URL("/images/Logo-Comandos.svg", site.url).toString(),
      },
    },
    image:
      imageObjects.length > 0 ? [primaryImage, ...imageObjects] : primaryImage,
    ...(caseStudy
      ? {
          hasPart: [
            { "@type": "WebPageElement", name: "Challenge" },
            { "@type": "WebPageElement", name: "Adventure" },
            { "@type": "WebPageElement", name: "Worth" },
            { "@type": "WebPageElement", name: "Result" },
          ],
        }
      : {}),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: site.url },
      {
        "@type": "ListItem",
        position: 2,
        name: "Projects",
        item: `${site.url}/projects`,
      },
      {
        "@type": "ListItem",
        position: 3,
        name: project.brand,
        item: `${site.url}/projects/${project.slug}`,
      },
    ],
  },
];
---

<BaseLayout
  title={project.title}
  description={project.description}
  type="article"
  image={ogVariant.src}
  jsonLd={jsonLd}
>
  {
    caseStudy ? (
      <>
        <CaseStudyNav />
        <CaseStudyHeader
          content={caseStudy}
          fallbackImage={project.image}
          title={project.title}
          description={project.description}
          impact={project.impact}
          timeline={project.timeline}
        />
        <Challenge content={caseStudy.challenge} brand={project.brand} />
        <Adventure content={caseStudy.adventure} />
        <Worth content={caseStudy.worth} />
        <Result content={caseStudy.result} />
        <RelatedCases cases={related} />
      </>
    ) : (
      <>
        <section class="container-page pt-12 md:pt-16 pb-10">
          <a href="/projects" class="btn-link mb-6">
            <span class="rotate-180 inline-block"><ArrowIcon /></span>
            All projects
          </a>

          <p class="text-xs font-semibold tracking-[0.18em] uppercase text-[color:var(--color-muted)]">
            {project.brand}
          </p>
          <h1 class="mt-3 text-3xl md:text-[3rem] font-extrabold leading-[1.05] tracking-tight max-w-3xl">
            {project.title}
          </h1>
          <p class="mt-5 max-w-2xl text-[1.0625rem] leading-[1.55] text-[color:var(--color-muted)]">
            {project.description}
          </p>

          <dl class="mt-8 flex flex-wrap gap-x-10 gap-y-3 text-sm">
            <div>
              <dt class="text-[color:var(--color-muted)] text-xs uppercase tracking-wider">Impact</dt>
              <dd class="mt-1 text-base font-semibold">{project.impact}</dd>
            </div>
            <div>
              <dt class="text-[color:var(--color-muted)] text-xs uppercase tracking-wider">Timeline</dt>
              <dd class="mt-1 text-base font-semibold">{project.timeline}</dd>
            </div>
          </dl>
        </section>

        <section class="container-page pb-24">
          <div class="overflow-hidden rounded-xl bg-[color:var(--color-paper-soft)]">
            <Image
              src={project.image}
              alt={`${project.brand} — ${project.title}`}
              widths={[640, 960, 1280, 1600]}
              sizes="(min-width: 1024px) 960px, 100vw"
              loading="eager"
              decoding="async"
              class="w-full h-auto object-cover aspect-[16/9]"
            />
          </div>

          <div class="mt-10 max-w-2xl space-y-6 text-[1rem] leading-[1.7] text-[color:var(--color-ink-soft)]">
            <p class="italic text-[color:var(--color-muted)]">
              Full case study content coming soon — Carlos will publish the detailed
              write-up with process, research, and final designs.
            </p>
          </div>
        </section>
      </>
    )
  }
</BaseLayout>
