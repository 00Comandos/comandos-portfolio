---
import BaseLayout from "~/layouts/BaseLayout.astro";
import ProjectCard from "~/components/projects/ProjectCard.astro";
import { projects } from "~/data/projects";
import { site } from "~/lib/site";

export const prerender = true;

const sorted = [...projects].sort((a, b) => a.order - b.order);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Projects — Comandos",
  url: `${site.url}/projects`,
  description:
    "Selected product design case studies by Comandos across FinTech, SaaS, IoT, and FoodTech.",
  hasPart: sorted.map((p) => ({
    "@type": "CreativeWork",
    name: p.title,
    url: `${site.url}/projects/${p.slug}`,
    about: p.brand,
  })),
};
---

<BaseLayout
  title="Projects"
  description="Selected product design case studies by Comandos: FinTech, SaaS, IoT, and FoodTech. Real outcomes, real metrics."
  jsonLd={jsonLd}
>
  <section class="container-page pt-12 md:pt-20 pb-20">
    <div class="grid gap-10 md:gap-16 md:grid-cols-[minmax(0,1fr)_minmax(0,2fr)]">
      <aside class="md:pt-6">
        <div class="md:sticky md:top-24">
          <h1 class="display-serif text-[3.25rem] md:text-[4rem] max-w-[14ch]">
            Building<br /><em>exponential<br />growth</em>
          </h1>
        </div>
      </aside>

      <div class="min-w-0 divide-y divide-[color:var(--color-border)]">
        {sorted.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>
</BaseLayout>
